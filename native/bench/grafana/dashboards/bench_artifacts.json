{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "spanNulls": true
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "connectanum_bench_artifact_workload_latency_avg_ms",
          "legendFormat": "{{scenario}} / {{workload}} / {{protocol}}",
          "refId": "A"
        }
      ],
      "title": "Artifact Latency Avg",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "spanNulls": true
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "connectanum_bench_artifact_workload_throughput_mbps",
          "legendFormat": "{{scenario}} / {{workload}} / {{protocol}}",
          "refId": "A"
        }
      ],
      "title": "Artifact Throughput",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 0,
            "spanNulls": true
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "connectanum_bench_artifact_workload_transport_delta_total{kind=~\"transport_alerts|goaway_alerts|backpressure_alerts|protocol_error_alerts|internal_error_alerts\"}",
          "legendFormat": "{{scenario}} / {{workload}} / {{kind}}",
          "refId": "A"
        }
      ],
      "title": "Artifact Alert Deltas",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "max(connectanum_bench_artifact_workload_transport_after{kind=\"active_throttles\"})",
          "legendFormat": "active throttles after workload",
          "refId": "A"
        }
      ],
      "title": "Artifact Active Throttles",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "connectanum_bench_artifact_workload_latency_avg_ms",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "connectanum_bench_artifact_workload_latency_p95_ms",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "connectanum_bench_artifact_workload_throughput_mbps",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "connectanum_bench_artifact_workload_transport_delta_total{kind=\"transport_alerts\"}",
          "format": "table",
          "instant": true,
          "refId": "D"
        }
      ],
      "title": "Artifact Snapshot Table",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["bench", "artifacts"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "title": "Connectanum Bench Artifacts",
  "version": 1
}
