#!/usr/bin/env bash

set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/common.sh"

usage() {
  cat <<'EOF'
Usage: bin/wamp-profile-validate [--out-dir <dir>] [--router-worker-counts <csv>] [--native-runtime-thread-counts <csv>] [--workload-timeout-ms <ms>]

Runs the canonical WAMP profile release gates:
1. cleartext RawSocket/WebSocket WAMP smoke
2. TLS RawSocket/WebSocket WAMP smoke
3. WAMP control-plane smoke
4. payload E2EE smoke
5. cleartext RawSocket/WebSocket WAMP throughput
6. TLS RawSocket/WebSocket WAMP throughput
7. native-client WAMP pub/sub fan-out throughput
8. AES-256-GCM payload E2EE throughput
9. final-release progressive invocation, call timeout, and Meta API gates

Each scenario writes transformed bench artifacts and validates them. Smoke
scenarios use the strict default transport-counter gate; throughput scenarios
also validate against checked-in performance policies.
EOF
}

absolute_path() {
  local path="$1"

  if [[ "$path" == /* ]]; then
    printf '%s\n' "$path"
  else
    printf '%s/%s\n' "$(repo_root)" "$path"
  fi
}

out_dir="$(repo_root)/out/wamp-profile-validation"
router_worker_counts="1"
native_runtime_thread_counts="1"
workload_timeout_ms="300000"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --out-dir)
      out_dir="$(absolute_path "$2")"
      shift 2
      ;;
    --router-worker-counts)
      router_worker_counts="$2"
      shift 2
      ;;
    --native-runtime-thread-counts)
      native_runtime_thread_counts="$2"
      shift 2
      ;;
    --workload-timeout-ms)
      workload_timeout_ms="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'Unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

require_command cargo
require_command dart
require_command rustc
cd_repo_root

mkdir -p "$out_dir"

build_native_ffi_test_release

if [[ -z "${CONNECTANUM_NATIVE_LIB:-}" ]]; then
  printf 'Failed to resolve CONNECTANUM_NATIVE_LIB for WAMP profile validation.\n' >&2
  exit 1
fi

{
  printf 'date_utc=%s\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf 'uname=%s\n' "$(uname -a)"
  printf 'rustc=%s\n' "$(rustc -V)"
  printf 'cargo=%s\n' "$(cargo -V)"
  printf 'dart=%s\n' "$(dart --version 2>&1 | tr '\n' ' ')"
  printf 'native_lib=%s\n' "$CONNECTANUM_NATIVE_LIB"
  printf 'router_worker_counts=%s\n' "$router_worker_counts"
  printf 'native_runtime_thread_counts=%s\n' "$native_runtime_thread_counts"
  printf 'workload_timeout_ms=%s\n' "$workload_timeout_ms"
} >"${out_dir%/}/host-info.txt"

run_gate() {
  local name="$1"
  local scenario="$2"
  local policy="${3:-}"
  local scenario_out="${out_dir%/}/$name"
  local results_path="${scenario_out%/}/bench_results.jsonl"

  scenario="$(absolute_path "$scenario")"

  if [[ ! -f "$scenario" ]]; then
    printf 'Missing WAMP scenario: %s\n' "$scenario" >&2
    exit 1
  fi

  if [[ -n "$policy" ]]; then
    policy="$(absolute_path "$policy")"
    if [[ ! -f "$policy" ]]; then
      printf 'Missing WAMP artifact policy: %s\n' "$policy" >&2
      exit 1
    fi
  fi

  mkdir -p "$scenario_out"

  printf 'Running %s...\n' "$name"
  cargo run --release --manifest-path native/bench/Cargo.toml --bin http_stream -- \
    --native-lib "$CONNECTANUM_NATIVE_LIB" \
    --scenario "$scenario" \
    --results "$results_path" \
    --artifact-dir "$scenario_out" \
    --router-worker-counts "$router_worker_counts" \
    --native-runtime-thread-counts "$native_runtime_thread_counts" \
    --workload-timeout-ms "$workload_timeout_ms"

  if [[ -n "$policy" ]]; then
    printf 'Checking %s against %s...\n' "$name" "$policy"
    bin/check-bench-artifacts \
      --summary "${scenario_out%/}/bench_results.summary.json" \
      --policy "$policy"
  else
    printf 'Checking %s against the default transport-counter gate...\n' "$name"
    bin/check-bench-artifacts \
      --summary "${scenario_out%/}/bench_results.summary.json"
  fi
}

run_gate \
  wamp_smoke \
  native/bench/scenarios/wamp_smoke.toml

run_gate \
  wamp_secure_smoke \
  native/bench/scenarios/wamp_secure_smoke.toml

run_gate \
  wamp_control_smoke \
  native/bench/scenarios/wamp_control_smoke.toml

run_gate \
  wamp_e2ee_smoke \
  native/bench/scenarios/wamp_e2ee_smoke.toml

run_gate \
  wamp_transport_throughput \
  native/bench/scenarios/wamp_transport_throughput.toml \
  native/bench/artifact_gate/wamp_transport_throughput.json

run_gate \
  wamp_secure_throughput \
  native/bench/scenarios/wamp_secure_throughput.toml \
  native/bench/artifact_gate/wamp_secure_throughput.json

run_gate \
  wamp_publish_fanout_throughput \
  native/bench/scenarios/wamp_publish_fanout_throughput.toml \
  native/bench/artifact_gate/wamp_publish_fanout_throughput.json

run_gate \
  wamp_e2ee_throughput \
  native/bench/scenarios/wamp_e2ee_throughput.toml \
  native/bench/artifact_gate/wamp_e2ee_throughput.json

run_gate \
  wamp_final_release_features \
  native/bench/scenarios/wamp_final_release_features.toml \
  native/bench/artifact_gate/wamp_final_release_features.json

printf 'WAMP profile validation artifacts written to %s\n' "$out_dir"
