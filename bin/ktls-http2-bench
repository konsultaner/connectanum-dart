#!/usr/bin/env bash

set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/common.sh"

usage() {
  cat <<'EOF'
Usage: bin/ktls-http2-bench [--scenario <path>] [--out-dir <dir>] [--router-worker-counts <csv>] [--native-runtime-thread-counts <csv>]

Runs the Linux-only HTTP/2 comparison bench:
1. baseline TLS over the existing HTTP/2 listener
2. required-kTLS over the same HTTP/2 listener

Outputs:
  <out-dir>/baseline/*
  <out-dir>/ktls/*
  <out-dir>/comparison.json
  <out-dir>/comparison.md

Environment:
  CONNECTANUM_ENABLE_KTLS            Forced to 0 for baseline and 1 for kTLS
  CONNECTANUM_REQUIRE_KTLS           Forced to 0 for baseline and 1 for kTLS
EOF
}

scenario="$(repo_root)/native/bench/scenarios/h2_ktls_benchmark.toml"
out_dir="$(repo_root)/out/ktls-http2-bench"
router_worker_counts="1"
native_runtime_thread_counts="1,4"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --scenario)
      scenario="$2"
      shift 2
      ;;
    --out-dir)
      out_dir="$2"
      shift 2
      ;;
    --router-worker-counts)
      router_worker_counts="$2"
      shift 2
      ;;
    --native-runtime-thread-counts)
      native_runtime_thread_counts="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'Unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

require_command cargo
require_command dart
require_command python3
cd_repo_root

if [[ "$(uname -s)" != "Linux" ]]; then
  printf 'bin/ktls-http2-bench requires Linux.\n' >&2
  exit 1
fi

mkdir -p "$out_dir"

scenario="$(cd "$(dirname "$scenario")" && pwd)/$(basename "$scenario")"
baseline_dir="${out_dir%/}/baseline"
ktls_dir="${out_dir%/}/ktls"
comparison_json="${out_dir%/}/comparison.json"
comparison_md="${out_dir%/}/comparison.md"
host_info_path="${out_dir%/}/host-info.txt"
artifact_policy="$(repo_root)/native/bench/artifact_gate/h2_ktls_benchmark.json"

build_native_ffi_test_release

printf 'Building release HTTP bench binary for stable comparison runs...\n'
cargo build --release --manifest-path native/bench/Cargo.toml --bin http_stream

if [[ -z "${CONNECTANUM_NATIVE_LIB:-}" ]]; then
  printf 'Failed to resolve CONNECTANUM_NATIVE_LIB for HTTP/2 kTLS benchmark.\n' >&2
  exit 1
fi

{
  printf 'date_utc=%s\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf 'uname=%s\n' "$(uname -a)"
  if [[ -r /proc/version ]]; then
    printf 'proc_version=%s\n' "$(tr '\n' ' ' </proc/version)"
  fi
  if [[ -r /proc/sys/net/ipv4/tcp_available_ulp ]]; then
    printf 'tcp_available_ulp=%s\n' "$(tr '\n' ' ' </proc/sys/net/ipv4/tcp_available_ulp)"
  fi
  printf 'rustc=%s\n' "$(rustc -V)"
  printf 'cargo=%s\n' "$(cargo -V)"
  printf 'dart=%s\n' "$("$(dart_binary)" --version 2>&1 | tr '\n' ' ')"
  printf 'scenario=%s\n' "$scenario"
  printf 'router_worker_counts=%s\n' "$router_worker_counts"
  printf 'native_runtime_thread_counts=%s\n' "$native_runtime_thread_counts"
  printf 'native_lib=%s\n' "$CONNECTANUM_NATIVE_LIB"
} >"$host_info_path"

run_pass() {
  local label="$1"
  local pass_out_dir="$2"
  local enable_ktls="$3"
  local require_ktls="$4"
  local pass_status=0
  local gate_status=0
  local resource_usage_path="${pass_out_dir}/resource-usage.txt"

  mkdir -p "$pass_out_dir"

  printf 'Running %s HTTP/2 bench (CONNECTANUM_ENABLE_KTLS=%s, CONNECTANUM_REQUIRE_KTLS=%s)...\n' \
    "$label" "$enable_ktls" "$require_ktls"

  if [[ -x /usr/bin/time ]]; then
    /usr/bin/time -v -o "$resource_usage_path" env \
      CONNECTANUM_ENABLE_KTLS="$enable_ktls" \
      CONNECTANUM_REQUIRE_KTLS="$require_ktls" \
      cargo run --release --manifest-path native/bench/Cargo.toml --bin http_stream -- \
        --native-lib "$CONNECTANUM_NATIVE_LIB" \
        --scenario "$scenario" \
        --results "${pass_out_dir}/bench_results.jsonl" \
        --artifact-dir "$pass_out_dir" \
        --router-worker-counts "$router_worker_counts" \
        --native-runtime-thread-counts "$native_runtime_thread_counts" \
        || pass_status=$?
  else
    printf 'resource_usage_capture=unavailable\nreason=/usr/bin/time not found\n' \
      >"$resource_usage_path"
    CONNECTANUM_ENABLE_KTLS="$enable_ktls" \
    CONNECTANUM_REQUIRE_KTLS="$require_ktls" \
    cargo run --release --manifest-path native/bench/Cargo.toml --bin http_stream -- \
      --native-lib "$CONNECTANUM_NATIVE_LIB" \
      --scenario "$scenario" \
      --results "${pass_out_dir}/bench_results.jsonl" \
      --artifact-dir "$pass_out_dir" \
      --router-worker-counts "$router_worker_counts" \
      --native-runtime-thread-counts "$native_runtime_thread_counts" \
      || pass_status=$?
  fi

  if [[ -f "${pass_out_dir}/bench_results.summary.json" ]]; then
    printf 'Checking %s bench artifacts for transport regressions...\n' "$label"
    bin/check-bench-artifacts \
      --summary "${pass_out_dir}/bench_results.summary.json" \
      --policy "$artifact_policy" \
      || gate_status=$?
  fi

  if (( pass_status != 0 )); then
    return "$pass_status"
  fi

  if (( gate_status != 0 )); then
    return "$gate_status"
  fi
}

baseline_status=0
ktls_status=0

run_pass baseline "$baseline_dir" 0 0 || baseline_status=$?
run_pass ktls "$ktls_dir" 1 1 || ktls_status=$?

python3 "$(repo_root)/tool/ktls_http2_compare.py" \
  "$baseline_dir/bench_results.summary.json" \
  "$ktls_dir/bench_results.summary.json" \
  "$comparison_json" \
  "$comparison_md"

if (( baseline_status != 0 || ktls_status != 0 )); then
  printf 'HTTP/2 benchmark pass statuses: baseline=%s ktls=%s\n' \
    "$baseline_status" "$ktls_status" >&2
  printf 'Partial benchmark artifacts were still written to %s\n' "$out_dir" >&2
  exit 1
fi

printf 'HTTP/2 TLS vs kTLS benchmark artifacts written to %s\n' "$out_dir"
