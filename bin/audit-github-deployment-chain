if [[ "$require_clean_wamp_profile_benchmarks" -eq 1 && "$wamp_profile_benchmarks_failed" -ne 0 ]]; then
  printf '\nWAMP profile benchmark audit failed.\n' >&2
  exit 1
fi

if [[ "$require_router_package" -eq 1 && "$missing_router_package" -ne 0 ]]; then
  printf '\nRouter package visibility audit failed.\n' >&2
  exit 1
fi

if [[ "$require_workflows_visible" -eq 1 && "$missing_visible_workflow" -ne 0 ]]; then
  printf '\nWorkflow visibility audit failed.\n' >&2
  exit 1
fi

if [[ "$strict" -eq 1 && ( "$release_missing_required_checks" -ne 0 || "$missing_visible_workflow" -ne 0 ) ]]; then
  printf '\nStrict audit failed: the release branch should require Fast Checks and Full Verify, and checked-in workflows should be visible to GitHub Actions.\n' >&2
  exit 1
fi

if [[ "$require_rc_ready" -eq 1 && "$rc_ready_failed" -ne 0 ]]; then
  printf '\nRelease candidate readiness audit failed.\n' >&2
  exit 1
fi
