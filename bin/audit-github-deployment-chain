  local candidate="$1"
  local expected_job

  for expected_job in "${expected_router_image_jobs[@]}"; do
    if [[ "$candidate" == "$expected_job" ]]; then
      return 0
    fi
  done

  return 1
}

is_expected_wamp_profile_benchmarks_job() {
  local candidate="$1"
  local expected_job

  for expected_job in "${expected_wamp_profile_benchmarks_jobs[@]}"; do
    if [[ "$candidate" == "$expected_job" ]]; then
      return 0
    fi
  done

  return 1
}

is_release_candidate_tag() {
  local tag="$1"

  [[ "$tag" =~ (^|[-_.])rc([0-9]+|[-_.][0-9]+)?($|[-_.]) ]]
}

is_numeric_release_candidate_tag() {
  local tag="$1"

  [[ "$tag" =~ ^.+[-_.]rc[-_.]?[0-9]+$ ]]
}

local_rc_tags_summary() {
  local target_sha="$1"
  local tag
  local tag_sha
  local status

  while IFS= read -r tag; do
    [[ -n "$tag" ]] || continue
    if ! is_release_candidate_tag "$tag"; then
      continue
    fi

    tag_sha="$(git rev-list -n 1 "$tag" 2>/dev/null || true)"
    [[ -n "$tag_sha" ]] || continue

    if [[ "$tag_sha" == "$target_sha" ]]; then
      status="current"
    else
      status="stale for checked-out head"
    fi

    printf '%s\t%s\t%s\n' "$tag" "$tag_sha" "$status"
  done < <(git tag --list | sort)
}

print_local_rc_tags_summary() {
  local target_sha="$1"
  local existing_rc_tags
  local tag
  local tag_sha
  local status

  existing_rc_tags="$(local_rc_tags_summary "$target_sha")"

  if [[ -z "$existing_rc_tags" ]]; then
    printf 'Existing local RC tags: none found.\n'
    return
  fi

  printf 'Existing local RC tags:\n'
  while IFS=$'\t' read -r tag tag_sha status; do
    [[ -n "$tag" ]] || continue
    printf -- '- %s -> %s (%s)\n' "$tag" "${tag_sha:0:7}" "$status"
  done <<<"$existing_rc_tags"
}

github_rc_tags_summary() {
  local target_sha="$1"
  local remote_url="https://github.com/${repository}.git"
  local remote_tags
  local tag
  local tag_sha
  local status

  remote_tags="$(git ls-remote --tags "$remote_url")" || return 1

  while IFS=$'\t' read -r tag tag_sha; do
    [[ -n "$tag" ]] || continue
    [[ -n "$tag_sha" ]] || continue
    if ! is_release_candidate_tag "$tag"; then
      continue
    fi

    if [[ "$tag_sha" == "$target_sha" ]]; then
      status="current"
    else
      status="stale for checked-out head"
    fi

    printf '%s\t%s\t%s\n' "$tag" "$tag_sha" "$status"
  done < <(
    printf '%s\n' "$remote_tags" \
      | awk '
          {
            sha = $1
            ref = $2
            sub("^refs/tags/", "", ref)
            peeled = 0
            if (ref ~ /\^\{\}$/) {
              sub(/\^\{\}$/, "", ref)
              peeled = 1
            }
            if (!(ref in seen)) {
              order[++count] = ref
              seen[ref] = 1
            }
            if (peeled || !(ref in sha_by_tag)) {
              sha_by_tag[ref] = sha
            }
          }
          END {
            for (i = 1; i <= count; i++) {
              tag = order[i]
              print tag "\t" sha_by_tag[tag]
            }
          }
        ' \
      | sort
  )
}

github_rc_tags_pointing_at() {
  local target_sha="$1"
  local tag
  local tag_sha
  local status

  while IFS=$'\t' read -r tag tag_sha status; do
    [[ -n "$tag" ]] || continue
    if [[ "$status" == "current" ]] && is_numeric_release_candidate_tag "$tag"; then
      printf '%s\n' "$tag"
    fi
  done < <(github_rc_tags_summary "$target_sha")
}

print_github_rc_tags_summary() {
  local target_sha="$1"
  local existing_rc_tags
  local tag
  local tag_sha
  local status

  if ! existing_rc_tags="$(github_rc_tags_summary "$target_sha")"; then
    printf 'Existing GitHub RC tags: unavailable; failed to inspect GitHub tags for %s.\n' "$repository"
    return
  fi

  if [[ -z "$existing_rc_tags" ]]; then
    printf 'Existing GitHub RC tags: none found.\n'
    return
  fi

  printf 'Existing GitHub RC tags:\n'
  while IFS=$'\t' read -r tag tag_sha status; do
    [[ -n "$tag" ]] || continue
    printf -- '- %s -> %s (%s)\n' "$tag" "${tag_sha:0:7}" "$status"
  done <<<"$existing_rc_tags"
}

followup_rc_tag_suggestions_from_summaries() {
  local existing_rc_tags="$1"
  local parsed=""
  local tag
  local tag_sha
  local status
  local prefix
  local number

  while IFS=$'\t' read -r tag tag_sha status; do
    [[ -n "$tag" ]] || continue
    if [[ "$tag" =~ ^(.+[-_.]rc[-_.]?)([0-9]+)$ ]]; then
      prefix="${BASH_REMATCH[1]}"
      number="${BASH_REMATCH[2]}"
      parsed="${parsed}${prefix}"$'\t'"$((10#$number))"$'\t'"${tag}"$'\n'
    fi
  done <<<"$existing_rc_tags"

  [[ -n "$parsed" ]] || return 0

  printf '%s' "$parsed" | awk -F '\t' '
    NF >= 3 {
      prefix = $1
      number = $2 + 0
      tag = $3
      if (!(prefix in seen) || number > max[prefix] || (number == max[prefix] && tag > source[prefix])) {
        seen[prefix] = 1
        max[prefix] = number
        source[prefix] = tag
      }
    }
    END {
      for (prefix in seen) {
        printf "%s%d\t%s\n", prefix, max[prefix] + 1, source[prefix]
      }
    }
  ' | sort
}

strict_dart_output_is_deferred_pub_dev_only() {
  local output_file="$1"
  local blocker_lines
  local unexpected_blockers

  grep -Fq 'All Dart package publish dry-runs reported zero warnings.' "$output_file" || return 1
  grep -Fq 'Dart package publish dry-run warning gate failed:' "$output_file" && return 1
  grep -Fq 'Dart package release-readiness blockers:' "$output_file" || return 1
  grep -Fq 'Dart package release-order plan:' "$output_file" || return 1
  grep -Fq 'Currently publishable package archives:' "$output_file" || return 1
  grep -Fq 'Private workspace packages blocking publishable targets:' "$output_file" || return 1
  grep -Eq '^- connectanum_core [^ ]+ \(packages/connectanum_core\)$' "$output_file" || return 1
  grep -Fq 'Workspace dependency order that must be satisfied before public publishing:' "$output_file" || return 1
  grep -Fq 'Operator decisions still required before a real publish:' "$output_file" || return 1

  blocker_lines="$(
    grep -E '^- .+ depends on private workspace package .+' "$output_file" || true
  )"

  [[ -n "$blocker_lines" ]] || return 1

  unexpected_blockers="$(
    printf '%s\n' "$blocker_lines" \
      | grep -Ev '^- connectanum_client depends on private workspace package connectanum_core \(packages/connectanum_core\); publish connectanum_core first or remove the hosted dependency before publishing connectanum_client\.$' \
      || true
  )"

  [[ -z "$unexpected_blockers" ]]
}

latest_workflow_run_id() {
  local workflow="$1"
  local run_id

  run_id="$(
    "$gh_bin" run list \
      --repo "$repository" \
      --branch "$branch" \
      --workflow "$workflow" \
      --limit 1 \
      --json databaseId \
      --jq '.[0].databaseId // empty'
  )"

  if [[ -n "$run_id" ]]; then
    printf '%s\n' "$run_id"
    return 0
  fi

  # GitHub can briefly index a completed run in the branch list before the
  # workflow-filtered list sees it. Fall back to the same branch run feed so a
  # fresh clean run does not false-fail the deployment-chain audit.
  "$gh_bin" run list \
    --repo "$repository" \
    --branch "$branch" \
    --limit "$run_limit" \
    --json name,databaseId \
    --jq '[.[] | select(.name == "'"$workflow"'")][0].databaseId // empty'
}

latest_ci_run_id() {
  latest_workflow_run_id CI
}

latest_dart_package_publish_dry_run_id() {
  latest_workflow_run_id "$dart_package_publish_workflow"
}

latest_native_release_dry_run_id() {
  latest_workflow_run_id "$native_release_workflow"
}

latest_wamp_profile_benchmarks_id() {
  latest_workflow_run_id "$wamp_profile_benchmarks_workflow"
}

router_image_run_looks_like_dry_run() {
  local run_id="$1"
  local run_state
  local run_event
  local login_conclusion

  run_state="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json event,jobs \
      --jq '[.event, ([.jobs[] | select(.name == "Publish Router Image") | .steps[] | select(.name == "Log in to GHCR") | (.conclusion // "pending")][0] // "")] | @tsv' \
      2>/dev/null || true
  )"

  [[ -n "$run_state" ]] || return 1

  IFS=$'\t' read -r run_event login_conclusion <<<"$run_state"

  # Manual publish runs log in to GHCR; dry-run validation skips that step. A
  # failed dry-run may abort before the conditional login step is evaluated, so
  # anything except a successful GHCR login remains relevant dry-run evidence.
  [[ "$run_event" == "workflow_dispatch" && "$login_conclusion" != "success" ]]
}

latest_router_image_dry_run_id() {
  local run_id

  while IFS= read -r run_id; do
    [[ -n "$run_id" ]] || continue
    if router_image_run_looks_like_dry_run "$run_id"; then
      printf '%s\n' "$run_id"
      return 0
    fi
  done < <(
    "$gh_bin" run list \
      --repo "$repository" \
      --branch "$branch" \
      --workflow "$router_image_workflow" \
      --limit 20 \
      --json databaseId \
      --jq '.[].databaseId'
  )
}

print_router_image_annotation_gate() {
  local run_id="$1"
  local run_jobs
  local job_id
  local job_name
  local annotations
  local annotation_level
  local annotation_path
  local annotation_line
  local annotation_message
  local location
  local failed=0

  run_jobs="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json jobs \
      --jq '.jobs[] | [.databaseId, .name] | @tsv'
  )"

  if [[ -z "$run_jobs" ]]; then
    printf 'Finding: latest Router Image dry-run has no jobs for annotation inspection.\n'
    return 1
  fi

  while IFS=$'\t' read -r job_id job_name; do
    [[ -n "$job_id" ]] || continue

    if ! annotations="$(
      "$gh_bin" api \
        --paginate \
        "repos/${repository}/check-runs/${job_id}/annotations" \
        --jq '.[] | select(.annotation_level == "warning" or .annotation_level == "failure") | [.annotation_level, (.path // ""), (.start_line // ""), .message] | @tsv'
    )"; then
      printf 'Finding: failed to inspect Router Image dry-run annotations for job %s.\n' "$job_name"
      failed=1
      continue
    fi

    [[ -n "$annotations" ]] || continue

    while IFS=$'\t' read -r annotation_level annotation_path annotation_line annotation_message; do
      [[ -n "$annotation_level" ]] || continue
      location=""
      if [[ -n "$annotation_path" ]]; then
        location=" (${annotation_path}"
        if [[ -n "$annotation_line" ]]; then
          location="${location}:${annotation_line}"
        fi
        location="${location})"
      fi
      printf 'Finding: Router Image dry-run check annotation on %s%s: %s: %s\n' \
        "$job_name" \
        "$location" \
        "$annotation_level" \
        "$annotation_message"
      failed=1
    done <<<"$annotations"
  done <<<"$run_jobs"

  if [[ "$failed" -eq 0 ]]; then
    printf 'Router image dry-run check annotations: clean.\n'
  fi

  return "$failed"
}

dart_package_publish_sensitive_changes_since() {
  local base="$1"
  local path

  git diff --name-only "${base}..HEAD" | while IFS= read -r path; do
    case "$path" in
      .github/workflows/dart-package-publish.yml|\
      bin/dart-package-publish-dry-run|\
      docs/dart_package_publishing.md|\
      packages/*|\
      packages/*/**)
        printf '%s\n' "$path"
        ;;
    esac
  done
}

native_release_sensitive_changes_since() {
  local base="$1"
  local path

  git diff --name-only "${base}..HEAD" | while IFS= read -r path; do
    case "$path" in
      .github/workflows/native-artifacts.yml|\
      bin/package-native-artifact|\
      bin/validate-native-release-install|\
      native/transport/*|\
      native/transport/**|\
      packages/connectanum_client/hook/*|\
      packages/connectanum_client/hook/**|\
      packages/connectanum_client/tool/install_native.dart|\
      packages/connectanum_router/hook/*|\
      packages/connectanum_router/hook/**|\
      packages/connectanum_router/tool/install_native.dart|\
      tool/render_native_release_notes.py|\
      tool/test_render_native_release_notes.py|\
      tool/validate_native_release_intent.py|\
      tool/test_validate_native_release_intent.py)
        printf '%s\n' "$path"
        ;;
    esac
  done
}

router_image_sensitive_changes_since() {
  local base="$1"
