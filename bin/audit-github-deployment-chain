  if ! print_router_image_dry_run_gate; then
    router_image_dry_run_failed=1
  fi
fi

if [[ "$check_wamp_profile_benchmarks" -eq 1 ]]; then
  printf '\n## Latest WAMP Profile Benchmarks\n\n'

  if ! print_wamp_profile_benchmark_gate; then
    wamp_profile_benchmarks_failed=1
  fi
fi

rc_ready_failed=0
if [[ "$show_rc_readiness" -eq 1 ]]; then
  if ! print_rc_readiness; then
    rc_ready_failed=1
  fi
fi

