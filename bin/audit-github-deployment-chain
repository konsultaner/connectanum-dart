}

print_latest_ci_log_scan() {
  local run_id="$1"
  local log_file
  local matches_file

  log_file="$(mktemp "${TMPDIR:-/tmp}/connectanum-ci-log.XXXXXX")"
  matches_file="$(mktemp "${TMPDIR:-/tmp}/connectanum-ci-log-matches.XXXXXX")"

  if ! "$gh_bin" run view "$run_id" --repo "$repository" --log >"$log_file"; then
    printf 'Finding: could not download logs for CI run #%s.\n' "$run_id"
    rm -f "$log_file" "$matches_file"
    return 1
  fi

  if LC_ALL=C grep -Eai "$ci_log_issue_pattern" "$log_file" >"$matches_file"; then
    printf 'Potential hosted CI log issues matching: %s\n' "$ci_log_issue_pattern"
    awk '
      NR <= 200 { print "- " $0 }
      END {
        if (NR > 200) {
          printf("- ... truncated %d additional matching lines\n", NR - 200)
        }
      }
    ' "$matches_file"
    rm -f "$log_file" "$matches_file"
    return 1
  fi

  printf 'Latest CI log scan is clean: no warning/deprecation/skipped/reset/connection-noise patterns found.\n'
  rm -f "$log_file" "$matches_file"
  return 0
}

print_dart_package_publish_dry_run_gate() {
  local run_id
  local run_summary
  local run_state
  local run_status
  local run_conclusion
  local run_head_sha
  local current_head_sha
  local run_jobs
  local job_name
  local job_status
  local job_conclusion
  local expected_job
  local changed_paths
  local failed=0

  run_id="$(latest_dart_package_publish_dry_run_id)"

  if [[ -z "$run_id" ]]; then
    printf 'Finding: no Dart Package Publish Dry Run workflow run found for branch %s.\n' "$branch"
    return 1
  fi

  run_summary="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json status,conclusion,headSha,url,displayTitle \
      --jq '"Run: Dart Package Publish Dry Run #'"$run_id"' \(.status)/\(.conclusion // "pending") @ \(.headSha[0:7])\nTitle: \(.displayTitle)\nURL: \(.url)"'
  )"
  printf '%s\n' "$run_summary"

  run_state="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json status,conclusion,headSha \
      --jq '[.status, (.conclusion // "pending"), .headSha] | @tsv'
  )"
  IFS=$'\t' read -r run_status run_conclusion run_head_sha <<<"$run_state"

  if [[ "$run_status" != "completed" || "$run_conclusion" != "success" ]]; then
    printf 'Finding: latest Dart package publish dry-run is not green: %s/%s.\n' "$run_status" "$run_conclusion"
    failed=1
  fi

  run_jobs="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json jobs \
      --jq '.jobs[] | [.name, .status, (.conclusion // "pending")] | @tsv'
  )"

  if [[ -z "$run_jobs" ]]; then
    printf 'Finding: latest Dart package publish dry-run has no inspectable jobs.\n'
    failed=1
  else
    while IFS=$'\t' read -r job_name job_status job_conclusion; do
      [[ -n "$job_name" ]] || continue
      printf -- '- %s: %s/%s\n' "$job_name" "$job_status" "$job_conclusion"

      if ! is_expected_dart_package_publish_job "$job_name"; then
        printf 'Finding: latest Dart package publish dry-run contains unexpected job: %s\n' "$job_name"
        failed=1
      fi

      if [[ "$job_conclusion" == "skipped" ]]; then
        printf 'Finding: latest Dart package publish dry-run job was skipped: %s\n' "$job_name"
        failed=1
      elif [[ "$job_status" != "completed" || "$job_conclusion" != "success" ]]; then
        printf 'Finding: latest Dart package publish dry-run job is not green: %s (%s/%s)\n' "$job_name" "$job_status" "$job_conclusion"
        failed=1
      fi
    done <<<"$run_jobs"

    for expected_job in "${expected_dart_package_publish_jobs[@]}"; do
      if ! printf '%s\n' "$run_jobs" | cut -f1 | grep -Fxq "$expected_job"; then
        printf 'Finding: latest Dart package publish dry-run is missing expected job: %s\n' "$expected_job"
        failed=1
      fi
    done
  fi

  current_head_sha="$(git rev-parse HEAD)"
  if [[ "$run_head_sha" == "$current_head_sha" ]]; then
    printf 'Dart package publish dry-run covers checked-out head: yes.\n'
  else
    if ! git cat-file -e "${run_head_sha}^{commit}" 2>/dev/null; then
      printf 'Finding: cannot compare Dart package publish dry-run head %s with checked-out head; commit is not available locally.\n' "${run_head_sha:0:7}"
      failed=1
    elif ! changed_paths="$(dart_package_publish_sensitive_changes_since "$run_head_sha")"; then
      printf 'Finding: failed to compare Dart package publish-sensitive paths since %s.\n' "${run_head_sha:0:7}"
      failed=1
    elif [[ -n "$changed_paths" ]]; then
      printf 'Finding: checked-out head has Dart package publish-sensitive changes after dry-run head %s:\n' "${run_head_sha:0:7}"
      while IFS= read -r changed_path; do
        [[ -n "$changed_path" ]] || continue
        printf -- '- %s\n' "$changed_path"
      done <<<"$changed_paths"
      failed=1
    else
      printf 'Dart package publish dry-run covers checked-out package inputs: yes; checked-out head differs from dry-run head %s, but no publish-sensitive paths changed since then.\n' "${run_head_sha:0:7}"
    fi
  fi

  if [[ "$failed" -eq 0 ]]; then
    printf 'Latest Dart package publish dry-run is clean and relevant.\n'
  fi

  return "$failed"
}

print_native_release_dry_run_gate() {
  native_release_evidence_tag=""
  native_release_evidence_mode=""
  native_release_evidence_scope=""

  local run_id
  local run_summary
  local run_state
  local run_status
  local run_conclusion
  local run_head_sha
  local run_event
  local current_head_sha
  local run_jobs
  local job_name
  local job_status
  local job_conclusion
  local expected_job
  local changed_paths
  local log_file
  local release_intent
  local release_scope=""
  local release_mode=""
  local release_tag=""
  local release_state
  local release_prerelease
  local release_draft
  local release_target
  local release_asset_count
  local failed=0

  run_id="$(latest_native_release_dry_run_id)"

  if [[ -z "$run_id" ]]; then
    printf 'Finding: no Native Artifacts workflow run found for branch %s.\n' "$branch"
    return 1
  fi

  run_summary="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json status,conclusion,headSha,url,displayTitle,event \
      --jq '"Run: Native Artifacts #'"$run_id"' \(.status)/\(.conclusion // "pending") @ \(.headSha[0:7])\nTitle: \(.displayTitle)\nEvent: \(.event)\nURL: \(.url)"'
  )"
  printf '%s\n' "$run_summary"

  run_state="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json status,conclusion,headSha,event \
      --jq '[.status, (.conclusion // "pending"), .headSha, .event] | @tsv'
  )"
  IFS=$'\t' read -r run_status run_conclusion run_head_sha run_event <<<"$run_state"

  if [[ "$run_status" != "completed" || "$run_conclusion" != "success" ]]; then
    printf 'Finding: latest Native Artifacts dry-run is not green: %s/%s.\n' "$run_status" "$run_conclusion"
    failed=1
  fi

  if [[ "$run_event" != "workflow_dispatch" ]]; then
    printf 'Finding: latest Native Artifacts evidence was not a manual dry-run dispatch: %s.\n' "$run_event"
    failed=1
  fi

  run_jobs="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json jobs \
      --jq '.jobs[] | [.name, .status, (.conclusion // "pending")] | @tsv'
  )"

  if [[ -z "$run_jobs" ]]; then
    printf 'Finding: latest Native Artifacts dry-run has no inspectable jobs.\n'
    failed=1
  else
    while IFS=$'\t' read -r job_name job_status job_conclusion; do
      [[ -n "$job_name" ]] || continue
      printf -- '- %s: %s/%s\n' "$job_name" "$job_status" "$job_conclusion"

      if ! is_expected_native_release_job "$job_name"; then
        printf 'Finding: latest Native Artifacts dry-run contains unexpected job: %s\n' "$job_name"
        failed=1
      fi

      if [[ "$job_conclusion" == "skipped" ]]; then
        printf 'Finding: latest Native Artifacts dry-run job was skipped: %s\n' "$job_name"
        failed=1
      elif [[ "$job_status" != "completed" || "$job_conclusion" != "success" ]]; then
        printf 'Finding: latest Native Artifacts dry-run job is not green: %s (%s/%s)\n' "$job_name" "$job_status" "$job_conclusion"
        failed=1
      fi
    done <<<"$run_jobs"

    for expected_job in "${expected_native_release_jobs[@]}"; do
      if ! printf '%s\n' "$run_jobs" | cut -f1 | grep -Fxq "$expected_job"; then
        printf 'Finding: latest Native Artifacts dry-run is missing expected job: %s\n' "$expected_job"
        failed=1
      fi
    done
  fi

  log_file="$(mktemp "${TMPDIR:-/tmp}/connectanum-native-release-log.XXXXXX")"
  if "$gh_bin" run view "$run_id" --repo "$repository" --log >"$log_file"; then
    release_intent="$(
      sed -nE 's/.*Release intent accepted: ([^ ]+) \(([^,]+), ([^)]+)\)\..*/\1\t\2\t\3/p' "$log_file" \
        | head -n 1
    )"

    if [[ -z "$release_intent" ]]; then
      printf 'Finding: latest Native Artifacts run did not log accepted release intent.\n'
      failed=1
    else
      IFS=$'\t' read -r release_tag release_scope release_mode <<<"$release_intent"
      native_release_evidence_tag="$release_tag"
      native_release_evidence_mode="$release_mode"
      native_release_evidence_scope="$release_scope"

      if [[ "$release_mode" == "dry-run" ]]; then
        printf 'Native release dry-run intent: accepted (%s, %s).\n' "$release_tag" "$release_scope"

        if "$gh_bin" release view "$release_tag" --repo "$repository" >/dev/null 2>&1; then
          printf 'Finding: dry-run release tag exists as a GitHub Release: %s.\n' "$release_tag"
          failed=1
        else
          printf 'Native release dry-run avoided GitHub Release mutation: yes (%s not found).\n' "$release_tag"
        fi

        if grep -Fq 'Artifact native-release-preview has been successfully uploaded!' "$log_file"; then
          printf 'Native release preview artifact upload: ready (native-release-preview).\n'
        else
          printf 'Finding: latest Native Artifacts dry-run did not upload native-release-preview.\n'
          failed=1
        fi
      elif [[ "$release_mode" == "prerelease" && "$accept_native_prerelease_evidence" -eq 1 ]]; then
        printf 'Native release prerelease intent: accepted (%s, %s).\n' "$release_tag" "$release_scope"

        if release_state="$(
          "$gh_bin" release view "$release_tag" \
            --repo "$repository" \
            --json isPrerelease,isDraft,targetCommitish,assets \
            --jq '[.isPrerelease, .isDraft, .targetCommitish, (.assets | length)] | @tsv' \
            2>/dev/null
        )"; then
          IFS=$'\t' read -r release_prerelease release_draft release_target release_asset_count <<<"$release_state"

          if [[ "$release_prerelease" == "true" && "$release_draft" != "true" ]]; then
            printf 'Native GitHub prerelease state: ready (%s is a non-draft prerelease).\n' "$release_tag"
          else
            printf 'Finding: GitHub Release %s isPrerelease=%s isDraft=%s.\n' "$release_tag" "$release_prerelease" "$release_draft"
            failed=1
          fi

          if [[ "$release_target" == "$run_head_sha" ]]; then
            printf 'Native GitHub prerelease target: ready (%s).\n' "${release_target:0:7}"
          else
            printf 'Finding: GitHub Release %s targets %s, expected %s.\n' "$release_tag" "${release_target:0:7}" "${run_head_sha:0:7}"
            failed=1
          fi

          if [[ "$release_asset_count" =~ ^[0-9]+$ && "$release_asset_count" -ge "$expected_native_release_asset_count" ]]; then
            printf 'Native GitHub prerelease assets: ready (%s assets).\n' "$release_asset_count"
          else
            printf 'Finding: GitHub Release %s has %s assets, expected at least %s.\n' "$release_tag" "${release_asset_count:-unknown}" "$expected_native_release_asset_count"
            failed=1
          fi
        else
          printf 'Finding: accepted prerelease intent did not create an inspectable GitHub Release: %s.\n' "$release_tag"
          failed=1
        fi
      else
        printf 'Finding: latest Native Artifacts run accepted %s/%s intent, not the required native dry-run evidence.\n' "$release_scope" "$release_mode"
        failed=1
      fi
    fi
  else
    printf 'Finding: could not download logs for Native Artifacts run #%s.\n' "$run_id"
    failed=1
  fi
  rm -f "$log_file"

  current_head_sha="$(git rev-parse HEAD)"
  if [[ "$run_head_sha" == "$current_head_sha" ]]; then
    printf 'Native release dry-run covers checked-out head: yes.\n'
  else
    if ! git cat-file -e "${run_head_sha}^{commit}" 2>/dev/null; then
      printf 'Finding: cannot compare Native Artifacts dry-run head %s with checked-out head; commit is not available locally.\n' "${run_head_sha:0:7}"
      failed=1
    elif ! changed_paths="$(native_release_sensitive_changes_since "$run_head_sha")"; then
      printf 'Finding: failed to compare native-release-sensitive paths since %s.\n' "${run_head_sha:0:7}"
      failed=1
    elif [[ -n "$changed_paths" ]]; then
      printf 'Finding: checked-out head has native-release-sensitive changes after dry-run head %s:\n' "${run_head_sha:0:7}"
      while IFS= read -r changed_path; do
        [[ -n "$changed_path" ]] || continue
        printf -- '- %s\n' "$changed_path"
      done <<<"$changed_paths"
      failed=1
    else
      printf 'Native release dry-run covers checked-out native release inputs: yes; checked-out head differs from dry-run head %s, but no native-release-sensitive paths changed since then.\n' "${run_head_sha:0:7}"
    fi
  fi

  if [[ "$failed" -eq 0 ]]; then
    if [[ "$release_mode" == "prerelease" ]]; then
      printf 'Latest Native Artifacts prerelease publish is clean and relevant.\n'
    else
      printf 'Latest Native Artifacts dry-run is clean and relevant.\n'
    fi
  fi

  return "$failed"
}

print_router_image_preview_metadata_gate() {
  local run_id="$1"
  local temp_dir
  local summary_file
  local image_owner
  local expected_image
  local primary_tag
  local primary_image_tag
  local failed=0

  image_owner="$(lowercase "$package_owner")"
  expected_image="ghcr.io/${image_owner}/connectanum-router"

  if ! temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/connectanum-router-image-preview.XXXXXX")"; then
    printf 'Finding: failed to create a temporary directory for Router Image preview metadata.\n'
    return 1
  fi

  if ! "$gh_bin" run download "$run_id" \
    --repo "$repository" \
    --name router-image-preview \
    --dir "$temp_dir" >/dev/null 2>&1; then
    printf 'Finding: failed to download router-image-preview artifact for Router Image dry-run #%s.\n' "$run_id"
    rm -rf "$temp_dir"
    return 1
  fi

  summary_file="$(find "$temp_dir" -type f -name router-image-metadata.md -print -quit)"

  if [[ -z "$summary_file" ]]; then
    printf 'Finding: router-image-preview artifact does not contain router-image-metadata.md.\n'
    failed=1
  elif [[ ! -s "$summary_file" ]]; then
    printf 'Finding: router-image-metadata.md is empty in router-image-preview artifact.\n'
    failed=1
  else
    if ! grep -Fxq -- "- Image: \`${expected_image}\`" "$summary_file"; then
      printf 'Finding: router image preview metadata does not target %s.\n' "$expected_image"
      failed=1
    fi

    if ! grep -Fxq -- '- Mode: `dry-run`' "$summary_file"; then
      printf 'Finding: router image preview metadata is not marked as dry-run mode.\n'
      failed=1
    fi

    if ! grep -Fxq -- '- Publish: `false`' "$summary_file"; then
      printf 'Finding: router image preview metadata is not marked publish=false.\n'
      failed=1
    fi

    primary_tag="$(
      awk '
        $0 == "### Tags" { in_tags = 1; next }
        in_tags && /^### / { exit }
        in_tags && /^- `/ {
          line = $0
          sub(/^- `/, "", line)
          sub(/`$/, "", line)
          print line
          exit
        }
      ' "$summary_file"
    )"

    if [[ -z "$primary_tag" ]]; then
      printf 'Finding: router image preview metadata does not include a primary tag.\n'
      failed=1
    elif [[ "$primary_tag" != "${expected_image}:"* ]]; then
      printf 'Finding: router image preview primary tag is not under %s: %s\n' "$expected_image" "$primary_tag"
      failed=1
    else
      primary_image_tag="${primary_tag#"${expected_image}:"}"

      if [[ -z "$primary_image_tag" ]]; then
        printf 'Finding: router image preview primary Docker tag is empty.\n'
        failed=1
      elif ! [[ "$primary_image_tag" =~ ^[A-Za-z0-9_][A-Za-z0-9_.-]{0,127}$ ]]; then
        printf 'Finding: router image preview primary Docker tag is invalid: %s\n' "$primary_image_tag"
        failed=1
      elif [[ "$primary_image_tag" =~ ^v[0-9]+\.[0-9]+\.[0-9]+($|[-.]) ]]; then
        printf 'Finding: router image preview primary Docker tag still uses a project-version v-prefix: %s\n' "$primary_image_tag"
        failed=1
      else
        printf 'Router image dry-run preview metadata: ready (%s).\n' "$primary_image_tag"
      fi
    fi
  fi

  rm -rf "$temp_dir"
  return "$failed"
}

print_router_image_dry_run_gate() {
  local run_id
  local run_summary
  local run_state
  local run_status
  local run_conclusion
  local run_head_sha
  local run_event
  local current_head_sha
  local run_jobs
  local run_steps
  local job_name
  local job_status
  local job_conclusion
  local expected_job
  local step_name
  local step_status
  local step_conclusion
  local changed_paths
  local has_metadata_step=0
  local has_preview_upload=0
  local has_login_skipped=0
  local has_build_step=0
  local failed=0

  run_id="$(latest_router_image_dry_run_id)"

  if [[ -z "$run_id" ]]; then
    printf 'Finding: no Router Image workflow run found for branch %s.\n' "$branch"
    return 1
  fi

  run_summary="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json status,conclusion,headSha,url,displayTitle,event \
      --jq '"Run: Router Image #'"$run_id"' \(.status)/\(.conclusion // "pending") @ \(.headSha[0:7])\nTitle: \(.displayTitle)\nEvent: \(.event)\nURL: \(.url)"'
  )"
  printf '%s\n' "$run_summary"

  run_state="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json status,conclusion,headSha,event \
      --jq '[.status, (.conclusion // "pending"), .headSha, .event] | @tsv'
  )"
  IFS=$'\t' read -r run_status run_conclusion run_head_sha run_event <<<"$run_state"

  if [[ "$run_status" != "completed" || "$run_conclusion" != "success" ]]; then
    printf 'Finding: latest Router Image dry-run is not green: %s/%s.\n' "$run_status" "$run_conclusion"
    failed=1
  fi

  if [[ "$run_event" != "workflow_dispatch" ]]; then
    printf 'Finding: latest Router Image evidence was not a manual dry-run dispatch: %s.\n' "$run_event"
    failed=1
  fi

  run_jobs="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json jobs \
      --jq '.jobs[] | [.name, .status, (.conclusion // "pending")] | @tsv'
  )"

  if [[ -z "$run_jobs" ]]; then
    printf 'Finding: latest Router Image dry-run has no inspectable jobs.\n'
    failed=1
  else
    while IFS=$'\t' read -r job_name job_status job_conclusion; do
      [[ -n "$job_name" ]] || continue
      printf -- '- %s: %s/%s\n' "$job_name" "$job_status" "$job_conclusion"

      if ! is_expected_router_image_job "$job_name"; then
        printf 'Finding: latest Router Image dry-run contains unexpected job: %s\n' "$job_name"
        failed=1
      fi

      if [[ "$job_status" != "completed" || "$job_conclusion" != "success" ]]; then
        printf 'Finding: latest Router Image dry-run job is not green: %s (%s/%s)\n' "$job_name" "$job_status" "$job_conclusion"
        failed=1
      fi
    done <<<"$run_jobs"

    for expected_job in "${expected_router_image_jobs[@]}"; do
      if ! printf '%s\n' "$run_jobs" | cut -f1 | grep -Fxq "$expected_job"; then
        printf 'Finding: latest Router Image dry-run is missing expected job: %s\n' "$expected_job"
        failed=1
      fi
    done
  fi

  run_steps="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json jobs \
      --jq '.jobs[] | select(.name == "Publish Router Image") | .steps[] | [.name, .status, (.conclusion // "pending")] | @tsv'
  )"

  if [[ -z "$run_steps" ]]; then
    printf 'Finding: latest Router Image dry-run has no inspectable steps.\n'
    failed=1
  else
    while IFS=$'\t' read -r step_name step_status step_conclusion; do
      [[ -n "$step_name" ]] || continue
      case "$step_name" in
        'Resolve image metadata')
          printf -- '- step %s: %s/%s\n' "$step_name" "$step_status" "$step_conclusion"
          if [[ "$step_status" == "completed" && "$step_conclusion" == "success" ]]; then
            has_metadata_step=1
          fi
          ;;
        'Upload router image preview')
          printf -- '- step %s: %s/%s\n' "$step_name" "$step_status" "$step_conclusion"
          if [[ "$step_status" == "completed" && "$step_conclusion" == "success" ]]; then
            has_preview_upload=1
          fi
          ;;
        'Log in to GHCR')
          printf -- '- step %s: %s/%s\n' "$step_name" "$step_status" "$step_conclusion"
          if [[ "$step_status" == "completed" && "$step_conclusion" == "skipped" ]]; then
            has_login_skipped=1
          fi
          ;;
        'Build or publish multi-arch router image')
          printf -- '- step %s: %s/%s\n' "$step_name" "$step_status" "$step_conclusion"
          if [[ "$step_status" == "completed" && "$step_conclusion" == "success" ]]; then
            has_build_step=1
          fi
          ;;
      esac
    done <<<"$run_steps"

    if [[ "$has_metadata_step" -ne 1 ]]; then
      printf 'Finding: latest Router Image dry-run did not resolve image metadata successfully.\n'
      failed=1
    fi

    if [[ "$has_preview_upload" -ne 1 ]]; then
      printf 'Finding: latest Router Image dry-run did not upload router-image-preview.\n'
      failed=1
    else
      printf 'Router image dry-run preview artifact upload: ready (router-image-preview).\n'
    fi

    if [[ "$has_preview_upload" -eq 1 ]] && ! print_router_image_preview_metadata_gate "$run_id"; then
      failed=1
    fi

    if [[ "$has_login_skipped" -ne 1 ]]; then
      printf 'Finding: latest Router Image dry-run did not skip GHCR login.\n'
      failed=1
    else
      printf 'Router image dry-run avoided GHCR login: yes.\n'
    fi

    if [[ "$has_build_step" -ne 1 ]]; then
      printf 'Finding: latest Router Image dry-run did not complete the multi-arch build step.\n'
      failed=1
    fi
  fi

  if ! print_router_image_annotation_gate "$run_id"; then
    failed=1
  fi

  current_head_sha="$(git rev-parse HEAD)"
  if [[ "$run_head_sha" == "$current_head_sha" ]]; then
    printf 'Router Image dry-run covers checked-out head: yes.\n'
  else
    if ! git cat-file -e "${run_head_sha}^{commit}" 2>/dev/null; then
      printf 'Finding: cannot compare Router Image dry-run head %s with checked-out head; commit is not available locally.\n' "${run_head_sha:0:7}"
      failed=1
    elif ! changed_paths="$(router_image_sensitive_changes_since "$run_head_sha")"; then
      printf 'Finding: failed to compare router-image-sensitive paths since %s.\n' "${run_head_sha:0:7}"
      failed=1
    elif [[ -n "$changed_paths" ]]; then
      printf 'Finding: checked-out head has router-image-sensitive changes after dry-run head %s:\n' "${run_head_sha:0:7}"
      while IFS= read -r changed_path; do
        [[ -n "$changed_path" ]] || continue
        printf -- '- %s\n' "$changed_path"
      done <<<"$changed_paths"
      failed=1
    else
      printf 'Router Image dry-run covers checked-out router image inputs: yes; checked-out head differs from dry-run head %s, but no router-image-sensitive paths changed since then.\n' "${run_head_sha:0:7}"
    fi
  fi

  if [[ "$failed" -eq 0 ]]; then
    printf 'Latest Router Image dry-run is clean and relevant.\n'
  fi

  return "$failed"
}

print_wamp_profile_benchmarks_gate() {
  local run_id
  local run_summary
  local run_state
  local run_status
  local run_conclusion
  local run_head_sha
  local run_event
  local current_head_sha
  local run_jobs
  local run_steps
  local job_name
  local job_status
  local job_conclusion
  local expected_job
  local step_name
  local step_status
  local step_conclusion
  local changed_paths
  local has_validate_step=0
  local has_artifact_upload=0
  local failed=0

  run_id="$(latest_wamp_profile_benchmarks_id)"

  if [[ -z "$run_id" ]]; then
    printf 'Finding: no WAMP Profile Benchmarks workflow run found for branch %s.\n' "$branch"
    return 1
  fi

  run_summary="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json status,conclusion,headSha,url,displayTitle,event \
      --jq '"Run: WAMP Profile Benchmarks #'"$run_id"' \(.status)/\(.conclusion // "pending") @ \(.headSha[0:7])\nTitle: \(.displayTitle)\nEvent: \(.event)\nURL: \(.url)"'
  )"
  printf '%s\n' "$run_summary"

  run_state="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json status,conclusion,headSha,event \
      --jq '[.status, (.conclusion // "pending"), .headSha, .event] | @tsv'
  )"
  IFS=$'\t' read -r run_status run_conclusion run_head_sha run_event <<<"$run_state"

  if [[ "$run_status" != "completed" || "$run_conclusion" != "success" ]]; then
    printf 'Finding: latest WAMP Profile Benchmarks run is not green: %s/%s.\n' "$run_status" "$run_conclusion"
    failed=1
  fi

  run_jobs="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json jobs \
      --jq '.jobs[] | [.name, .status, (.conclusion // "pending")] | @tsv'
  )"

  if [[ -z "$run_jobs" ]]; then
    printf 'Finding: latest WAMP Profile Benchmarks run has no inspectable jobs.\n'
    failed=1
  else
    while IFS=$'\t' read -r job_name job_status job_conclusion; do
      [[ -n "$job_name" ]] || continue
      printf -- '- %s: %s/%s\n' "$job_name" "$job_status" "$job_conclusion"

      if ! is_expected_wamp_profile_benchmarks_job "$job_name"; then
        printf 'Finding: latest WAMP Profile Benchmarks run contains unexpected job: %s\n' "$job_name"
        failed=1
      fi

      if [[ "$job_conclusion" == "skipped" ]]; then
        printf 'Finding: latest WAMP Profile Benchmarks job was skipped: %s\n' "$job_name"
        failed=1
      elif [[ "$job_status" != "completed" || "$job_conclusion" != "success" ]]; then
        printf 'Finding: latest WAMP Profile Benchmarks job is not green: %s (%s/%s)\n' "$job_name" "$job_status" "$job_conclusion"
        failed=1
      fi
    done <<<"$run_jobs"

    for expected_job in "${expected_wamp_profile_benchmarks_jobs[@]}"; do
      if ! printf '%s\n' "$run_jobs" | cut -f1 | grep -Fxq "$expected_job"; then
        printf 'Finding: latest WAMP Profile Benchmarks run is missing expected job: %s\n' "$expected_job"
        failed=1
      fi
    done
  fi

  run_steps="$(
    "$gh_bin" run view "$run_id" \
      --repo "$repository" \
      --json jobs \
      --jq '.jobs[] | select(.name == "Linux WAMP profile gates") | .steps[] | [.name, .status, (.conclusion // "pending")] | @tsv'
  )"

  if [[ -z "$run_steps" ]]; then
    printf 'Finding: latest WAMP Profile Benchmarks run has no inspectable steps.\n'
    failed=1
  else
    while IFS=$'\t' read -r step_name step_status step_conclusion; do
      [[ -n "$step_name" ]] || continue
      case "$step_name" in
        'Run canonical WAMP profile gates')
          printf -- '- step %s: %s/%s\n' "$step_name" "$step_status" "$step_conclusion"
          if [[ "$step_status" == "completed" && "$step_conclusion" == "success" ]]; then
            has_validate_step=1
          fi
          ;;
        'Upload WAMP profile artifacts')
          printf -- '- step %s: %s/%s\n' "$step_name" "$step_status" "$step_conclusion"
          if [[ "$step_status" == "completed" && "$step_conclusion" == "success" ]]; then
            has_artifact_upload=1
          fi
          ;;
      esac
    done <<<"$run_steps"

    if [[ "$has_validate_step" -ne 1 ]]; then
      printf 'Finding: latest WAMP Profile Benchmarks run did not complete canonical WAMP profile gates.\n'
      failed=1
    fi

    if [[ "$has_artifact_upload" -ne 1 ]]; then
      printf 'Finding: latest WAMP Profile Benchmarks run did not upload wamp-profile-benchmark-artifacts.\n'
      failed=1
    else
      printf 'WAMP profile benchmark artifact upload: ready (wamp-profile-benchmark-artifacts).\n'
    fi
  fi

  current_head_sha="$(git rev-parse HEAD)"
  if [[ "$run_head_sha" == "$current_head_sha" ]]; then
    printf 'WAMP Profile Benchmarks run covers checked-out head: yes.\n'
  else
    if ! git cat-file -e "${run_head_sha}^{commit}" 2>/dev/null; then
      printf 'Finding: cannot compare WAMP Profile Benchmarks head %s with checked-out head; commit is not available locally.\n' "${run_head_sha:0:7}"
      failed=1
    elif ! changed_paths="$(wamp_profile_benchmarks_sensitive_changes_since "$run_head_sha")"; then
      printf 'Finding: failed to compare WAMP profile benchmark-sensitive paths since %s.\n' "${run_head_sha:0:7}"
      failed=1
    elif [[ -n "$changed_paths" ]]; then
      printf 'Finding: checked-out head has WAMP profile benchmark-sensitive changes after benchmark head %s:\n' "${run_head_sha:0:7}"
      while IFS= read -r changed_path; do
        [[ -n "$changed_path" ]] || continue
        printf -- '- %s\n' "$changed_path"
      done <<<"$changed_paths"
      failed=1
    else
      printf 'WAMP Profile Benchmarks run covers checked-out WAMP profile inputs: yes; checked-out head differs from benchmark head %s, but no WAMP profile benchmark-sensitive paths changed since then.\n' "${run_head_sha:0:7}"
    fi
  fi

  if [[ "$failed" -eq 0 ]]; then
    printf 'Latest WAMP Profile Benchmarks run is clean and relevant.\n'
  fi

  return "$failed"
}

print_required_checks_plan() {
  local target_branch="$1"
  local protected="$2"
  local existing_strict="$3"
  local strict_value="false"
  local expected_job
  local job_count="${#expected_ci_jobs[@]}"
  local index=0

  if [[ "$existing_strict" == "true" ]]; then
    strict_value="true"
  fi

  printf '\n## Required Status Check Operator Plan\n\n'
  printf 'This audit does not change GitHub settings. Apply this only after operator approval.\n\n'

  if [[ "$protected" != "true" ]]; then
    printf 'Branch %s is not protected, so the required-status-check endpoint is unavailable until branch protection exists.\n' "$target_branch"
    printf 'Recommended autonomous action: keep using clean hosted CI evidence; do not protect development branches silently.\n'
    return
  fi

  printf 'Target branch: %s\n' "$target_branch"
  printf 'Required checks to add or preserve:\n'
  for expected_job in "${expected_ci_jobs[@]}"; do
    printf -- '- %s\n' "$expected_job"
  done
  printf 'Require up-to-date branches: %s\n\n' "$strict_value"

  printf 'Minimal required-status-check payload:\n\n'
  printf '```json\n'
  printf '{\n'
  printf '  "strict": %s,\n' "$strict_value"
  printf '  "contexts": [\n'
  for expected_job in "${expected_ci_jobs[@]}"; do
    index=$((index + 1))
    if [[ "$index" -lt "$job_count" ]]; then
      printf '    "%s",\n' "$expected_job"
    else
      printf '    "%s"\n' "$expected_job"
    fi
  done
  printf '  ]\n'
  printf '}\n'
  printf '```\n\n'

  printf 'Operator command, after saving the reviewed payload as required-status-checks.json:\n\n'
  printf '```sh\n'
  printf 'gh api \\\n'
  printf '  --method PATCH \\\n'
  printf '  repos/%s/branches/%s/protection/required_status_checks \\\n' "$repository" "$target_branch"
  printf '  --input required-status-checks.json\n'
  printf '```\n'
}

print_latest_ci_next_action() {
  local current_head_sha

  if [[ -z "${latest_ci_id:-}" ]]; then
    printf '  Next action: trigger or wait for a CI run on %s, then rerun bin/audit-github-deployment-chain --branch %s --require-clean-latest-ci.\n' "$branch" "$branch"
  elif [[ "${latest_ci_status:-}" != "completed" ]]; then
    printf '  Next action: wait for CI run #%s to complete, then rerun bin/audit-github-deployment-chain --branch %s --require-clean-latest-ci.\n' "$latest_ci_id" "$branch"
  elif [[ "${latest_ci_conclusion:-}" != "success" ]]; then
    printf '  Next action: inspect CI run #%s, fix the failed/skipped/missing job signal, push a new candidate, then rerun bin/audit-github-deployment-chain --branch %s --require-clean-latest-ci.\n' "$latest_ci_id" "$branch"
  elif current_head_sha="$(git rev-parse HEAD 2>/dev/null)" && [[ -n "${latest_ci_head_sha:-}" && "$latest_ci_head_sha" != "$current_head_sha" ]]; then
    printf '  Next action: push or wait for CI on checked-out head %s, then rerun bin/audit-github-deployment-chain --branch %s --require-clean-latest-ci.\n' "${current_head_sha:0:7}" "$branch"
  else
    printf '  Next action: inspect CI run #%s for unexpected or missing jobs, then rerun bin/audit-github-deployment-chain --branch %s --require-clean-latest-ci after the job set matches release policy.\n' "$latest_ci_id" "$branch"
  fi
}

print_latest_ci_log_next_action() {
  local current_head_sha

  if [[ -z "${latest_ci_id:-}" ]]; then
    printf '  Next action: trigger or wait for a CI run on %s, then rerun bin/audit-github-deployment-chain --branch %s --require-clean-latest-ci-logs.\n' "$branch" "$branch"
  elif [[ "${latest_ci_log_status:-}" != "completed" ]]; then
    printf '  Next action: wait for CI run #%s to complete so logs are downloadable, then rerun bin/audit-github-deployment-chain --branch %s --require-clean-latest-ci-logs.\n' "$latest_ci_id" "$branch"
  elif [[ "${latest_ci_log_conclusion:-}" != "success" ]]; then
    printf '  Next action: resolve CI run #%s before treating hosted logs as release evidence, then rerun bin/audit-github-deployment-chain --branch %s --require-clean-latest-ci-logs.\n' "$latest_ci_id" "$branch"
  elif current_head_sha="$(git rev-parse HEAD 2>/dev/null)" && [[ -n "${latest_ci_log_head_sha:-}" && "$latest_ci_log_head_sha" != "$current_head_sha" ]]; then
    printf '  Next action: push or wait for CI logs on checked-out head %s, then rerun bin/audit-github-deployment-chain --branch %s --require-clean-latest-ci-logs.\n' "${current_head_sha:0:7}" "$branch"
  else
    printf '  Next action: inspect the hosted log findings above, fix any real warning/noise source or retry if GitHub log download failed, then rerun bin/audit-github-deployment-chain --branch %s --require-clean-latest-ci-logs.\n' "$branch"
  fi
}

print_rc_readiness() {
  local rc_ready_failed=0
  local head_sha
  local short_head_sha
  local short_audited_branch_head_sha
  local branch_head_alignment_failed=0
  local default_branch_selection_failed=0
  local local_rc_tags
  local github_rc_tags
  local rc_tags
  local rc_tag
  local selected_rc_tag=""
  local selected_rc_release_state=""
  local existing_rc_tag_summaries
  local followup_rc_tag_suggestions
  local followup_rc_tag
  local followup_source_tag
  local prefer_github_rc_tag
  local selected_router_image_tag
  local selected_router_image_digest
  local strict_dart_output
  local rc_tag_source

  head_sha="$(git rev-parse HEAD)"
  short_head_sha="${head_sha:0:7}"

  printf '\n## Release Candidate Readiness\n\n'
  printf 'Checked-out head: %s\n' "$short_head_sha"
  if [[ -z "${audited_branch_head_sha:-}" ]]; then
    printf 'Audited branch head: unknown (%s)\n' "$branch"
    printf 'Branch/head alignment: not ready; could not inspect the audited branch head.\n'
    printf '  Next action: confirm the audited branch exists and rerun bin/audit-github-deployment-chain --branch %s --show-rc-readiness before selecting an RC tag.\n' "$branch"
    branch_head_alignment_failed=1
    rc_ready_failed=1
  else
    short_audited_branch_head_sha="${audited_branch_head_sha:0:7}"
    printf 'Audited branch head: %s (%s)\n' "$short_audited_branch_head_sha" "$branch"
    if [[ "$audited_branch_head_sha" == "$head_sha" ]]; then
      printf 'Branch/head alignment: ready\n'
    else
      printf 'Branch/head alignment: not ready; audited branch %s points at %s while the checkout is %s.\n' "$branch" "$short_audited_branch_head_sha" "$short_head_sha"
      printf '  Next action: check out %s at %s or promote/rebase the candidate so the audited branch and checkout match before selecting an RC tag.\n' "$branch" "$short_audited_branch_head_sha"
      branch_head_alignment_failed=1
      rc_ready_failed=1
    fi
  fi

  if [[ "$branch" == "$default_branch" ]]; then
    printf 'Audited branch role: ready (default branch %s)\n' "$default_branch"
  else
    printf 'Audited branch role: not ready; RC releases must be audited from default branch %s, but audited branch is %s.\n' "$default_branch" "$branch"
    printf '  Next action: promote or check out the candidate on %s, then rerun bin/audit-github-deployment-chain --branch %s --show-rc-readiness before selecting an RC tag.\n' "$default_branch" "$default_branch"
    default_branch_selection_failed=1
    rc_ready_failed=1
  fi

  if [[ "$check_clean_latest_ci" -eq 1 ]]; then
    if [[ "$latest_ci_failed" -eq 0 ]]; then
      printf 'Latest CI job gate: ready\n'
    else
      printf 'Latest CI job gate: not ready\n'
      print_latest_ci_next_action
      rc_ready_failed=1
    fi
  else
    printf 'Latest CI job gate: not evaluated; use --require-clean-latest-ci or --require-rc-ready.\n'
    rc_ready_failed=1
  fi

  if [[ "$scan_latest_ci_logs" -eq 1 ]]; then
    if [[ "$latest_ci_log_failed" -eq 0 ]]; then
      printf 'Latest CI log gate: ready\n'
    else
      printf 'Latest CI log gate: not ready\n'
      print_latest_ci_log_next_action
      rc_ready_failed=1
    fi
  else
    printf 'Latest CI log gate: not evaluated; use --scan-latest-ci-logs or --require-rc-ready.\n'
    rc_ready_failed=1
  fi

  if [[ "$check_dart_package_publish_dry_run" -eq 1 ]]; then
    if [[ "$dart_package_publish_dry_run_failed" -eq 0 ]]; then
      printf 'Dart package hosted dry-run gate: ready\n'
    else
      printf 'Dart package hosted dry-run gate: not ready\n'
      rc_ready_failed=1
    fi
  else
    printf 'Dart package hosted dry-run gate: not evaluated; use --show-dart-package-publish-dry-run or --require-rc-ready.\n'
    rc_ready_failed=1
  fi

  if [[ "$check_native_release_dry_run" -eq 1 ]]; then
    if [[ "$native_release_dry_run_failed" -eq 0 ]]; then
      printf 'Native release hosted evidence gate: ready\n'
    else
      printf 'Native release hosted evidence gate: not ready\n'
      rc_ready_failed=1
    fi
  else
    printf 'Native release hosted evidence gate: not evaluated; use --show-native-release-dry-run or --require-rc-ready.\n'
    rc_ready_failed=1
  fi

  if [[ "$check_router_image_dry_run" -eq 1 ]]; then
    if [[ "$router_image_dry_run_failed" -eq 0 ]]; then
      printf 'Router image hosted dry-run gate: ready\n'
    else
      printf 'Router image hosted dry-run gate: not ready\n'
      rc_ready_failed=1
    fi
  else
    printf 'Router image hosted dry-run gate: not evaluated; use --show-router-image-dry-run or --require-rc-ready.\n'
    rc_ready_failed=1
  fi

  if [[ "$check_wamp_profile_benchmarks" -eq 1 ]]; then
    if [[ "$wamp_profile_benchmarks_failed" -eq 0 ]]; then
      printf 'WAMP profile benchmark gate: ready\n'
    else
      printf 'WAMP profile benchmark gate: not ready\n'
      rc_ready_failed=1
    fi
  else
    printf 'WAMP profile benchmark gate: not evaluated; use --show-wamp-profile-benchmarks or --require-rc-ready.\n'
    rc_ready_failed=1
  fi

  if [[ "$release_missing_required_checks" -eq 0 ]]; then
    printf 'Default branch protection baseline: ready (%s requires %s)\n' "$release_protection_branch" "${release_required_contexts:-none}"
  else
    if [[ -z "$release_branch_protected" ]]; then
      printf 'Default branch protection baseline: not ready; could not inspect %s.\n' "$release_protection_branch"
    elif [[ "$release_branch_protected" != "true" ]]; then
      printf 'Default branch protection baseline: not ready; %s is not protected.\n' "$release_protection_branch"
    else
      printf 'Default branch protection baseline: not ready; %s must require release-critical CI checks (current: %s).\n' "$release_protection_branch" "${release_required_contexts:-none}"
    fi
    printf '  Next action: run bin/audit-github-deployment-chain --branch %s --show-required-checks-plan and apply the reviewed GitHub branch-protection change only after operator approval.\n' "$release_protection_branch"
    rc_ready_failed=1
  fi

  if [[ "$missing_visible_workflow" -eq 0 ]]; then
    printf 'Workflow visibility: ready\n'
  else
    printf 'Workflow visibility: not ready; every checked-in workflow must be visible to GitHub Actions.\n'
    printf '  Next action: promote the missing workflow file(s) through %s, then rerun bin/audit-github-deployment-chain --branch %s --require-workflows-visible.\n' "$default_branch" "$branch"
    rc_ready_failed=1
  fi

  if [[ "$missing_router_package" -eq 0 ]]; then
    printf 'Router image package visibility: ready\n'
  else
    printf 'Router image package visibility: not ready; ghcr.io/%s/connectanum-router is not visible.\n' "$package_owner"
    printf '  Next action: after release approval, publish the router image and rerun bin/audit-github-deployment-chain --branch %s --require-router-package.\n' "$branch"
    rc_ready_failed=1
  fi

  local_rc_tags="$(
    while IFS= read -r rc_tag; do
      [[ -n "$rc_tag" ]] || continue
      if is_numeric_release_candidate_tag "$rc_tag"; then
        printf '%s\n' "$rc_tag"
      fi
    done < <(git tag --points-at HEAD | sort)
  )"
  github_rc_tags="$(github_rc_tags_pointing_at "$head_sha" 2>/dev/null || true)"
  prefer_github_rc_tag=0
  if [[ -n "$github_rc_tags" ]]; then
    prefer_github_rc_tag=1
  fi
  rc_tags="$(
    {
      printf '%s\n' "$github_rc_tags"
      printf '%s\n' "$local_rc_tags"
    } | sed '/^$/d' | sort -u
  )"

  if [[ -z "$rc_tags" ]]; then
    printf 'RC tag on checked-out head: not ready; no local or GitHub numeric RC tag points at %s.\n' "$short_head_sha"
    print_local_rc_tags_summary "$head_sha"
    print_github_rc_tags_summary "$head_sha"
    existing_rc_tag_summaries="$(
      {
        local_rc_tags_summary "$head_sha"
        github_rc_tags_summary "$head_sha" 2>/dev/null || true
      } | sed '/^$/d' | sort -u
    )"
    if [[ "$branch_head_alignment_failed" -eq 0 && "$default_branch_selection_failed" -eq 0 ]]; then
      followup_rc_tag_suggestions="$(followup_rc_tag_suggestions_from_summaries "$existing_rc_tag_summaries")"
      if [[ -n "$followup_rc_tag_suggestions" ]]; then
        printf 'Suggested follow-up RC tag(s):\n'
        while IFS=$'\t' read -r followup_rc_tag followup_source_tag; do
          [[ -n "$followup_rc_tag" ]] || continue
          printf -- '- %s (next numeric tag after %s; requires release approval before pushing)\n' "$followup_rc_tag" "$followup_source_tag"
        done <<<"$followup_rc_tag_suggestions"
      else
        printf 'Suggested follow-up RC tag(s): unavailable; no existing numeric RC tag suffix was found.\n'
      fi
    elif [[ "$branch_head_alignment_failed" -ne 0 ]]; then
      printf 'Suggested follow-up RC tag(s): not evaluated until audited branch head and checked-out head match.\n'
    else
      printf 'Suggested follow-up RC tag(s): not evaluated until the audited branch is the default release branch.\n'
    fi
    if [[ "$branch_head_alignment_failed" -eq 0 && "$default_branch_selection_failed" -eq 0 ]]; then
      printf '  Next action: choose whether release policy should move an existing stale RC tag or approve a follow-up RC tag at %s, push it, then create a GitHub prerelease after release approval.\n' "$short_head_sha"
    elif [[ "$branch_head_alignment_failed" -ne 0 ]]; then
      printf '  Next action: align the audited branch and checkout first; only then choose whether release policy should move an existing stale RC tag or approve a follow-up RC tag.\n'
    else
      printf '  Next action: audit the default branch before choosing whether release policy should move an existing stale RC tag or approve a follow-up RC tag.\n'
    fi
    rc_ready_failed=1
  else
    printf 'RC tag on checked-out head: ready\n'
    while IFS= read -r rc_tag; do
      [[ -n "$rc_tag" ]] || continue
      rc_tag_source=""
      if printf '%s\n' "$github_rc_tags" | grep -Fxq "$rc_tag"; then
        rc_tag_source="GitHub"
        printf -- '- %s (GitHub)\n' "$rc_tag"
      elif printf '%s\n' "$local_rc_tags" | grep -Fxq "$rc_tag"; then
        rc_tag_source="local"
        printf -- '- %s (local)\n' "$rc_tag"
      else
        printf -- '- %s\n' "$rc_tag"
      fi
      if [[ -z "$selected_rc_tag" ]]; then
        if [[ "$prefer_github_rc_tag" -eq 0 || "$rc_tag_source" == "GitHub" ]]; then
          selected_rc_tag="$rc_tag"
        fi
      fi
    done <<<"$rc_tags"
  fi

  if [[ -n "$selected_rc_tag" ]]; then
    if [[ "$native_release_dry_run_failed" -eq 0 && "${native_release_evidence_mode:-}" == "prerelease" ]]; then
      if [[ "${native_release_evidence_tag:-}" == "$selected_rc_tag" ]]; then
        printf 'Native release prerelease tag: ready (%s)\n' "$selected_rc_tag"
      else
        printf 'Native release prerelease tag: not ready; latest accepted native prerelease is %s, selected RC tag is %s.\n' "${native_release_evidence_tag:-unknown}" "$selected_rc_tag"
        printf '  Next action: publish native artifacts for the selected RC tag or approve a new RC tag that matches the existing native prerelease evidence.\n'
        rc_ready_failed=1
      fi
    fi

    if ! printf '%s\n' "$github_rc_tags" | grep -Fxq "$selected_rc_tag"; then
      printf 'GitHub RC prerelease: not ready; %s is not a GitHub tag at checked-out head %s.\n' "$selected_rc_tag" "$short_head_sha"
      printf '  Next action: push the approved RC tag to GitHub after release approval, then create or refresh the non-draft GitHub prerelease for that tag.\n'
      rc_ready_failed=1
    elif selected_rc_release_state="$(
      "$gh_bin" release view "$selected_rc_tag" \
        --repo "$repository" \
        --json tagName,isPrerelease,isDraft \
        --jq '[.tagName, .isPrerelease, .isDraft] | @tsv' \
        2>/dev/null
    )"; then
      IFS=$'\t' read -r release_tag release_prerelease release_draft <<<"$selected_rc_release_state"
      if [[ "$release_prerelease" == "true" && "$release_draft" != "true" ]]; then
        printf 'GitHub RC prerelease: ready (%s)\n' "$release_tag"
      else
        printf 'GitHub RC prerelease: not ready; %s isPrerelease=%s isDraft=%s.\n' "$release_tag" "$release_prerelease" "$release_draft"
        rc_ready_failed=1
      fi
    else
      printf 'GitHub RC prerelease: not ready; no GitHub Release exists for %s.\n' "$selected_rc_tag"
      printf '  Next action: create a non-draft GitHub prerelease for %s after the tag and release notes are approved.\n' "$selected_rc_tag"
      rc_ready_failed=1
    fi

    selected_router_image_tag="$(router_image_tag_for_rc_tag "$selected_rc_tag")"
    if selected_router_image_digest="$(ghcr_registry_manifest_digest "$package_owner" "$selected_router_image_tag" 2>/dev/null)"; then
      printf 'Router image RC tag: ready (%s, %s)\n' "$selected_router_image_tag" "$selected_router_image_digest"
    else
      printf 'Router image RC tag: not ready; ghcr.io/%s/connectanum-router:%s is not publicly reachable.\n' "$(lowercase "$package_owner")" "$selected_router_image_tag"
      printf '  Next action: after release approval, publish the Router Image workflow for %s or rerun the tag-triggered image publish, then rerun bin/audit-github-deployment-chain --branch %s --require-rc-ready.\n' "$selected_rc_tag" "$branch"
      rc_ready_failed=1
    fi
  else
    printf 'GitHub RC prerelease: not ready; no RC tag selected.\n'
    printf '  Next action: select and push an RC tag before creating the GitHub prerelease.\n'
    printf 'Router image RC tag: not ready; no RC tag selected.\n'
    rc_ready_failed=1
  fi

  if [[ -x "$dart_package_publish_dry_run_bin" ]]; then
    strict_dart_output="$(mktemp "${TMPDIR:-/tmp}/connectanum-dart-pub-strict.XXXXXX")"
    if "$dart_package_publish_dry_run_bin" --strict-release-ready --show-release-plan >"$strict_dart_output" 2>&1; then
      printf 'Dart package strict publish dry-run: ready\n'
    elif strict_dart_output_is_deferred_pub_dev_only "$strict_dart_output"; then
      printf 'Dart package strict publish dry-run: deferred for first GitHub RC\n'
      grep -E '^(Dart package release-readiness blockers:|Dart package release-order plan:|Currently publishable package archives:|Private workspace packages not currently publishable:|Private workspace packages blocking publishable targets:|Workspace dependency order that must be satisfied before public publishing:|Operator decisions still required before a real publish:|- )' "$strict_dart_output" || true
      printf '  Deferred: pub.dev publishing is intentionally outside this GitHub prerelease RC; keep the archive dry-run zero-warning and resolve package ownership/version/release-order before public publishing.\n'
    else
      printf 'Dart package strict publish dry-run: not ready\n'
      grep -E '^(Dart package release-readiness blockers:|Dart package release-order plan:|Currently publishable package archives:|Private workspace packages not currently publishable:|Private workspace packages blocking publishable targets:|Workspace dependency order that must be satisfied before public publishing:|Operator decisions still required before a real publish:|- )' "$strict_dart_output" || true
      printf '  Next action: resolve the package ownership/version/release-order decisions in docs/dart_package_publishing.md, then rerun bin/dart-package-publish-dry-run --strict-release-ready --show-release-plan.\n'
      rc_ready_failed=1
    fi
    rm -f "$strict_dart_output"
  else
    printf 'Dart package strict publish dry-run: not ready; %s is missing or not executable.\n' "$dart_package_publish_dry_run_bin"
    rc_ready_failed=1
  fi

  if [[ "$rc_ready_failed" -eq 0 ]]; then
    printf '\nRelease candidate readiness: ready.\n'
  else
    printf '\nRelease candidate readiness: not ready.\n'
  fi

  return "$rc_ready_failed"
}

if [[ -z "$branch" ]]; then
  branch="$(api_jq "" '.default_branch')"
fi

repo_visibility="$(api_jq "" '.visibility')"
repo_private="$(api_jq "" '.private')"
default_branch="$(api_jq "" '.default_branch')"
allow_auto_merge="$(api_jq "" '.allow_auto_merge')"
delete_branch_on_merge="$(api_jq "" '.delete_branch_on_merge')"
branch_protected="$(api_jq_optional "branches/${branch}" '.protected')"
audited_branch_head_sha="$(api_jq_optional "branches/${branch}" '.commit.sha // empty')"
release_protection_branch="$default_branch"
ruleset_count="$(api_jq_optional "rulesets" 'length')"
package_owner="${repository%%/*}"

printf '# GitHub Deployment Chain Audit\n\n'
printf 'Repository: %s\n' "$repository"
printf 'Visibility: %s (private=%s)\n' "$repo_visibility" "$repo_private"
printf 'Default branch: %s\n' "$default_branch"
printf 'Audited branch: %s\n' "$branch"
printf 'Allow auto-merge: %s\n' "$allow_auto_merge"
printf 'Delete branch on merge: %s\n' "$delete_branch_on_merge"
printf 'Repository rulesets: %s\n\n' "${ruleset_count:-unknown}"

printf '## Branch Protection\n\n'

if [[ -z "$branch_protected" ]]; then
  printf 'Branch exists/protection status: unknown\n'
  printf 'Finding: could not inspect branch %s.\n' "$branch"
  exit 1
fi

printf 'Protected: %s\n' "$branch_protected"

missing_required_checks=0
release_missing_required_checks=0
release_branch_protected=""
release_required_contexts=""
missing_visible_workflow=0
missing_router_package=0
latest_ci_failed=0
latest_ci_log_failed=0
dart_package_publish_dry_run_failed=0
native_release_dry_run_failed=0
native_release_evidence_tag=""
native_release_evidence_mode=""
native_release_evidence_scope=""
router_image_dry_run_failed=0
wamp_profile_benchmarks_failed=0
latest_ci_id=""
latest_ci_status=""
latest_ci_conclusion=""
latest_ci_head_sha=""
latest_ci_log_status=""
latest_ci_log_conclusion=""
latest_ci_log_head_sha=""
required_contexts=""

if [[ "$branch_protected" == "true" ]]; then
  required_contexts="$(
    api_jq_optional \
      "branches/${branch}/protection" \
      '((.required_status_checks.contexts // []) + ((.required_status_checks.checks // []) | map(.context))) | unique | join(", ")'
  )"
  status_strict="$(
    api_jq_optional \
      "branches/${branch}/protection" \
      '.required_status_checks.strict // false'
  )"
  require_pull_requests="$(
    api_jq_optional \
      "branches/${branch}/protection" \
      '.required_pull_request_reviews != null'
  )"
  review_count="$(
    api_jq_optional \
      "branches/${branch}/protection" \
      '.required_pull_request_reviews.required_approving_review_count // 0'
  )"
  code_owner_reviews="$(
    api_jq_optional \
      "branches/${branch}/protection" \
      '.required_pull_request_reviews.require_code_owner_reviews // false'
  )"
  enforce_admins="$(api_jq_optional "branches/${branch}/protection" '.enforce_admins.enabled // false')"
  allow_force_pushes="$(api_jq_optional "branches/${branch}/protection" '.allow_force_pushes.enabled // false')"
  allow_deletions="$(api_jq_optional "branches/${branch}/protection" '.allow_deletions.enabled // false')"
  linear_history="$(api_jq_optional "branches/${branch}/protection" '.required_linear_history.enabled // false')"
  conversation_resolution="$(api_jq_optional "branches/${branch}/protection" '.required_conversation_resolution.enabled // false')"
  admin_bypass_allowed="unknown"
  case "$enforce_admins" in
    true) admin_bypass_allowed="false" ;;
    false) admin_bypass_allowed="true" ;;
  esac

  printf 'Required status checks: %s\n' "${required_contexts:-none}"
  printf 'Require up-to-date branches: %s\n' "$status_strict"
  printf 'Require pull requests: %s\n' "$require_pull_requests"
  printf 'Required approving reviews: %s\n' "$review_count"
  printf 'Require code-owner reviews: %s\n' "$code_owner_reviews"
  printf 'Enforce admins: %s\n' "$enforce_admins"
  printf 'Admin bypass allowed: %s\n' "$admin_bypass_allowed"
  printf 'Allow force pushes: %s\n' "$allow_force_pushes"
  printf 'Allow deletions: %s\n' "$allow_deletions"
  printf 'Required linear history: %s\n' "$linear_history"
  printf 'Required conversation resolution: %s\n' "$conversation_resolution"

  for expected_check in 'Fast Checks' 'Full Verify'; do
    if [[ "$required_contexts" != *"$expected_check"* ]]; then
      printf 'Finding: missing required status check: %s\n' "$expected_check"
      missing_required_checks=1
    fi
  done
else
  printf 'Required status checks: none\n'
  printf 'Require pull requests: false\n'
  printf 'Admin bypass allowed: n/a (branch is not protected)\n'
  printf 'Finding: branch is not protected.\n'
  missing_required_checks=1
fi

if [[ "$release_protection_branch" == "$branch" ]]; then
  release_branch_protected="$branch_protected"
  release_required_contexts="$required_contexts"
  release_missing_required_checks="$missing_required_checks"
else
  release_branch_protected="$(api_jq_optional "branches/${release_protection_branch}" '.protected')"
  if [[ "$release_branch_protected" == "true" ]]; then
    release_required_contexts="$(
      api_jq_optional \
        "branches/${release_protection_branch}/protection" \
        '((.required_status_checks.contexts // []) + ((.required_status_checks.checks // []) | map(.context))) | unique | join(", ")'
    )"
    for expected_check in "${expected_ci_jobs[@]}"; do
      if [[ "$release_required_contexts" != *"$expected_check"* ]]; then
        release_missing_required_checks=1
      fi
    done
  else
    release_missing_required_checks=1
  fi
fi

if [[ "$show_required_checks_plan" -eq 1 ]]; then
  print_required_checks_plan "$branch" "$branch_protected" "${status_strict:-false}"
fi

printf '\n## Active Workflows\n\n'
api_jq_optional \
  "actions/workflows" \
  '.workflows[] | "- \(.name): \(.state) (\(.path))"'

printf '\n## Checked-In Workflow Visibility\n\n'

active_workflow_paths="$(
  api_jq_optional \
    "actions/workflows" \
    '.workflows[].path'
)"

workflow_count=0
while IFS= read -r workflow_path; do
  [[ -n "$workflow_path" ]] || continue
  workflow_path="${workflow_path#./}"
  workflow_count=$((workflow_count + 1))

  if printf '%s\n' "$active_workflow_paths" | grep -Fxq "$workflow_path"; then
    printf -- '- %s: discoverable\n' "$workflow_path"
  else
    printf -- '- %s: not discoverable through GitHub Actions API\n' "$workflow_path"
    default_branch_workflow_error="$(mktemp "${TMPDIR:-/tmp}/connectanum-workflow-visibility.XXXXXX")"
    if "$gh_bin" api \
      --method GET \
      "repos/${repository}/contents/${workflow_path}" \
      -F "ref=${default_branch}" \
      --jq '.path' >/dev/null 2>"$default_branch_workflow_error"; then
      printf '  Default branch check: present on %s; inspect workflow state or repository Actions settings.\n' "$default_branch"
    elif grep -q 'HTTP 404' "$default_branch_workflow_error"; then
      printf '  Default branch check: missing from %s; promote the workflow through the default branch before expecting Actions API visibility.\n' "$default_branch"
    else
      default_branch_workflow_error_message="$(head -n 1 "$default_branch_workflow_error")"
      printf '  Default branch check: inconclusive; GitHub content lookup failed'
      if [[ -n "$default_branch_workflow_error_message" ]]; then
        printf ' (%s)' "$default_branch_workflow_error_message"
      fi
      printf '.\n'
    fi
    rm -f "$default_branch_workflow_error"
    printf 'Finding: checked-in workflow is not discoverable by GitHub: %s\n' "$workflow_path"
    missing_visible_workflow=1
  fi
done < <(
  find .github/workflows \
    -maxdepth 1 \
    -type f \
    \( -name '*.yml' -o -name '*.yaml' \) \
    -print 2>/dev/null \
    | sed 's#^\./##' \
    | sort
)

if [[ "$workflow_count" -eq 0 ]]; then
  printf 'No checked-in workflow files found.\n'
fi

printf '\n## Router Container Package\n\n'

router_package=""
router_registry_summary=""
router_registry_name=""
router_registry_tag_count=""
router_registry_manifest_tag=""
router_registry_manifest_digest=""
router_registry_tags_preview=""
router_registry_status="not-found"

if router_registry_summary="$(ghcr_registry_package_summary "$package_owner" 2>/dev/null)"; then
  router_registry_name="$(printf '%s\n' "$router_registry_summary" | sed -n '1p')"
  router_registry_tag_count="$(printf '%s\n' "$router_registry_summary" | sed -n '2p')"
  router_registry_manifest_tag="$(printf '%s\n' "$router_registry_summary" | sed -n '3p')"
  router_registry_manifest_digest="$(printf '%s\n' "$router_registry_summary" | sed -n '4p')"
  router_registry_tags_preview="$(printf '%s\n' "$router_registry_summary" | sed -n '5,14p')"
  router_registry_status="visible"
  router_package="connectanum-router"
fi

if candidate_package="$(
  "$gh_bin" api "users/${package_owner}/packages/container/connectanum-router" \
    --jq '.name' 2>/dev/null
)"; then
  router_package="$candidate_package"
elif candidate_package="$(
  "$gh_bin" api "orgs/${package_owner}/packages/container/connectanum-router" \
    --jq '.name' 2>/dev/null
)"; then
  router_package="$candidate_package"
fi

if [[ "$router_registry_status" == "visible" ]]; then
  printf 'GHCR registry package: ghcr.io/%s/connectanum-router (public pull metadata reachable)\n' "$(lowercase "$package_owner")"
  printf 'GHCR registry name: %s\n' "$router_registry_name"
  printf 'GHCR registry tags visible: %s\n' "$router_registry_tag_count"
  printf 'GHCR registry manifest probe: %s (%s)\n' "$router_registry_manifest_tag" "$router_registry_manifest_digest"
  if [[ -n "$router_registry_tags_preview" ]]; then
    printf 'GHCR registry tag preview:\n'
    while IFS= read -r router_registry_tag; do
      [[ -n "$router_registry_tag" ]] || continue
      printf -- '- %s\n' "$router_registry_tag"
    done <<<"$router_registry_tags_preview"
  fi
elif [[ -n "$router_package" ]]; then
  printf 'GHCR package metadata: ghcr.io/%s/%s\n' "$package_owner" "$router_package"
  printf 'Note: public GHCR registry pull metadata is not currently reachable for ghcr.io/%s/connectanum-router; package metadata was visible only through the GitHub Packages API fallback.\n' "$(lowercase "$package_owner")"
else
  printf 'GHCR package: not found for ghcr.io/%s/connectanum-router\n' "$(lowercase "$package_owner")"
  printf 'Finding: router container package is not currently visible through the public GHCR registry API or GitHub Packages metadata.\n'
  missing_router_package=1
fi

printf '\n## Latest Branch Runs\n\n'
"$gh_bin" run list \
  --repo "$repository" \
  --branch "$branch" \
  --limit "$run_limit" \
  --json name,databaseId,status,conclusion,headSha,createdAt \
  --jq '.[] | "- \(.name) #\(.databaseId): \(.status)/\(.conclusion // "pending") @ \(.headSha[0:7]) (\(.createdAt))"' \
  || true

if [[ "$check_clean_latest_ci" -eq 1 ]]; then
  printf '\n## Latest CI Job Cleanliness\n\n'

  latest_ci_id="$(latest_ci_run_id)"

  if [[ -z "$latest_ci_id" ]]; then
    printf 'Finding: no CI run found for branch %s.\n' "$branch"
    latest_ci_failed=1
  else
    latest_ci_summary="$(
      "$gh_bin" run view "$latest_ci_id" \
        --repo "$repository" \
        --json status,conclusion,headSha,url \
        --jq '"Run: CI #'"$latest_ci_id"' \(.status)/\(.conclusion // "pending") @ \(.headSha[0:7])\nURL: \(.url)"'
    )"
    printf '%s\n' "$latest_ci_summary"

    latest_ci_state="$(
      "$gh_bin" run view "$latest_ci_id" \
        --repo "$repository" \
        --json status,conclusion,headSha \
        --jq '[.status, (.conclusion // "pending"), .headSha] | @tsv'
    )"
    IFS=$'\t' read -r latest_ci_status latest_ci_conclusion latest_ci_head_sha <<<"$latest_ci_state"

    if [[ "$latest_ci_status" != "completed" || "$latest_ci_conclusion" != "success" ]]; then
      printf 'Finding: latest CI run is not green: %s/%s.\n' "$latest_ci_status" "$latest_ci_conclusion"
      latest_ci_failed=1
    fi

    current_head_sha="$(git rev-parse HEAD)"
    if [[ "$latest_ci_head_sha" != "$current_head_sha" ]]; then
      printf 'Finding: latest CI run does not cover checked-out head: run head %s, checked-out head %s.\n' "${latest_ci_head_sha:0:7}" "${current_head_sha:0:7}"
      latest_ci_failed=1
    else
      printf 'Latest CI run covers checked-out head: yes.\n'
    fi

    latest_ci_jobs="$(
      "$gh_bin" run view "$latest_ci_id" \
        --repo "$repository" \
        --json jobs \
        --jq '.jobs[] | [.name, .status, (.conclusion // "pending")] | @tsv'
    )"

    if [[ -z "$latest_ci_jobs" ]]; then
      printf 'Finding: latest CI run has no inspectable jobs.\n'
      latest_ci_failed=1
    else
      while IFS=$'\t' read -r job_name job_status job_conclusion; do
        [[ -n "$job_name" ]] || continue
        printf -- '- %s: %s/%s\n' "$job_name" "$job_status" "$job_conclusion"

        if ! is_expected_ci_job "$job_name"; then
          printf 'Finding: latest CI run contains unexpected job: %s\n' "$job_name"
          latest_ci_failed=1
        fi

        if [[ "$job_conclusion" == "skipped" ]]; then
          printf 'Finding: latest CI job was skipped: %s\n' "$job_name"
          latest_ci_failed=1
        elif [[ "$job_status" != "completed" || "$job_conclusion" != "success" ]]; then
          printf 'Finding: latest CI job is not green: %s (%s/%s)\n' "$job_name" "$job_status" "$job_conclusion"
          latest_ci_failed=1
        fi
      done <<<"$latest_ci_jobs"

      for expected_job in "${expected_ci_jobs[@]}"; do
        if ! printf '%s\n' "$latest_ci_jobs" | cut -f1 | grep -Fxq "$expected_job"; then
          printf 'Finding: latest CI run is missing expected job: %s\n' "$expected_job"
          latest_ci_failed=1
        fi
      done
    fi

    if [[ "$latest_ci_failed" -eq 0 ]]; then
      printf 'Latest CI run is clean: no skipped, pending, failed, missing, or unexpected jobs.\n'
    fi
  fi
fi

if [[ "$scan_latest_ci_logs" -eq 1 ]]; then
  printf '\n## Latest CI Log Scan\n\n'

  if [[ -z "$latest_ci_id" ]]; then
    latest_ci_id="$(latest_ci_run_id)"
  fi

  if [[ -z "$latest_ci_id" ]]; then
    printf 'Finding: no CI run found for branch %s.\n' "$branch"
    latest_ci_log_failed=1
  else
    latest_ci_log_summary="$(
      "$gh_bin" run view "$latest_ci_id" \
        --repo "$repository" \
        --json status,conclusion,headSha,url \
        --jq '"Run: CI #'"$latest_ci_id"' \(.status)/\(.conclusion // "pending") @ \(.headSha[0:7])\nURL: \(.url)"'
    )"
    printf '%s\n' "$latest_ci_log_summary"

    latest_ci_log_state="$(
      "$gh_bin" run view "$latest_ci_id" \
        --repo "$repository" \
        --json status,conclusion,headSha \
        --jq '[.status, (.conclusion // "pending"), .headSha] | @tsv'
    )"
    IFS=$'\t' read -r latest_ci_log_status latest_ci_log_conclusion latest_ci_log_head_sha <<<"$latest_ci_log_state"

    if [[ "$require_clean_latest_ci_logs" -eq 1 && ( "$latest_ci_log_status" != "completed" || "$latest_ci_log_conclusion" != "success" ) ]]; then
      printf 'Finding: latest CI logs are not a complete green signal yet: %s/%s.\n' "$latest_ci_log_status" "$latest_ci_log_conclusion"
      latest_ci_log_failed=1
    fi

    current_head_sha="$(git rev-parse HEAD)"
    if [[ "$latest_ci_log_head_sha" != "$current_head_sha" ]]; then
      printf 'Finding: latest CI logs do not cover checked-out head: run head %s, checked-out head %s.\n' "${latest_ci_log_head_sha:0:7}" "${current_head_sha:0:7}"
      latest_ci_log_failed=1
    else
      printf 'Latest CI logs cover checked-out head: yes.\n'
    fi

    if ! print_latest_ci_log_scan "$latest_ci_id"; then
      latest_ci_log_failed=1
    fi
  fi
fi

if [[ "$check_dart_package_publish_dry_run" -eq 1 ]]; then
  printf '\n## Latest Dart Package Publish Dry Run\n\n'

  if ! print_dart_package_publish_dry_run_gate; then
    dart_package_publish_dry_run_failed=1
  fi
fi

if [[ "$check_native_release_dry_run" -eq 1 ]]; then
  printf '\n## Latest Native Release Dry Run\n\n'

  if ! print_native_release_dry_run_gate; then
    native_release_dry_run_failed=1
  fi
fi

if [[ "$check_router_image_dry_run" -eq 1 ]]; then
  printf '\n## Latest Router Image Dry Run\n\n'

  if ! print_router_image_dry_run_gate; then
    router_image_dry_run_failed=1
  fi
fi

if [[ "$check_wamp_profile_benchmarks" -eq 1 ]]; then
  printf '\n## Latest WAMP Profile Benchmarks\n\n'

  if ! print_wamp_profile_benchmarks_gate; then
    wamp_profile_benchmarks_failed=1
  fi
fi

rc_ready_failed=0
if [[ "$show_rc_readiness" -eq 1 ]]; then
  if ! print_rc_readiness; then
    rc_ready_failed=1
  fi
fi

if [[ "$require_clean_latest_ci" -eq 1 && "$latest_ci_failed" -ne 0 ]]; then
  printf '\nLatest CI cleanliness audit failed.\n' >&2
  exit 1
fi

if [[ "$require_clean_latest_ci_logs" -eq 1 && "$latest_ci_log_failed" -ne 0 ]]; then
  printf '\nLatest CI log-scan audit failed.\n' >&2
  exit 1
fi

if [[ "$require_clean_dart_package_publish_dry_run" -eq 1 && "$dart_package_publish_dry_run_failed" -ne 0 ]]; then
  printf '\nDart package publish dry-run audit failed.\n' >&2
  exit 1
fi

if [[ "$require_clean_native_release_dry_run" -eq 1 && "$native_release_dry_run_failed" -ne 0 ]]; then
  printf '\nNative release dry-run audit failed.\n' >&2
  exit 1
fi

if [[ "$require_clean_router_image_dry_run" -eq 1 && "$router_image_dry_run_failed" -ne 0 ]]; then
  printf '\nRouter image dry-run audit failed.\n' >&2
  exit 1
fi

if [[ "$require_clean_wamp_profile_benchmarks" -eq 1 && "$wamp_profile_benchmarks_failed" -ne 0 ]]; then
  printf '\nWAMP Profile Benchmarks audit failed.\n' >&2
  exit 1
fi

if [[ "$require_router_package" -eq 1 && "$missing_router_package" -ne 0 ]]; then
  printf '\nRouter package visibility audit failed.\n' >&2
  exit 1
fi

if [[ "$require_workflows_visible" -eq 1 && "$missing_visible_workflow" -ne 0 ]]; then
  printf '\nWorkflow visibility audit failed.\n' >&2
  exit 1
fi

if [[ "$strict" -eq 1 && ( "$missing_required_checks" -ne 0 || "$missing_visible_workflow" -ne 0 ) ]]; then
  printf '\nStrict audit failed: protected release branches should require Fast Checks and Full Verify, and checked-in workflows should be visible to GitHub Actions.\n' >&2
  exit 1
fi

if [[ "$require_rc_ready" -eq 1 && "$rc_ready_failed" -ne 0 ]]; then
  printf '\nRelease candidate readiness audit failed.\n' >&2
  exit 1
fi
