#!/usr/bin/env bash

set -euo pipefail

source "$(dirname "$0")/common.sh"

usage() {
  cat <<'USAGE'
Usage: bin/audit-github-deployment-chain [options]

Prints a read-only GitHub deployment-chain audit for the repository: default
branch protection, required status checks, repository rulesets, active workflows,
and the latest branch runs.

Options:
  --repository <owner/repo>  Repository to inspect. Defaults to
                             GITHUB_REPOSITORY or konsultaner/connectanum-dart.
  --branch <branch>         Branch to inspect. Defaults to the repository
                             default branch.
  --run-limit <count>       Latest branch runs to print. Defaults to 6.
  --require-clean-latest-ci
                             Exit non-zero unless the latest CI run on the
                             audited branch covers the checked-out head and
                             completed with exactly the expected main jobs and
                             no skipped, pending, or failed jobs.
  --scan-latest-ci-logs      Print high-signal warning/skipped-test/noisy
                             runtime matches from the latest CI run logs.
  --require-clean-latest-ci-logs
                             Exit non-zero if the latest CI run logs contain
                             high-signal warning/skipped-test/noisy runtime
                             matches, if the run is not complete and green, or
                             if the run does not cover the checked-out head.
  --show-dart-package-publish-dry-run
                             Print the latest dedicated Dart package publish
                             dry-run workflow evidence.
  --require-clean-dart-package-publish-dry-run
                             Exit non-zero unless the latest relevant Dart
                             package publish dry-run workflow completed
                             successfully and still covers the checked-out
                             package-publishing inputs.
  --show-native-release-dry-run
                             Print the latest dedicated native release dry-run
                             workflow evidence.
  --require-clean-native-release-dry-run
                             Exit non-zero unless the latest relevant Native
                             Artifacts dry-run workflow completed successfully,
                             uploaded the preview artifact, avoided release
                             mutation, and still covers the checked-out native
                             release inputs.
  --show-router-image-dry-run
                             Print the latest dedicated Router Image dry-run
                             workflow evidence.
  --require-clean-router-image-dry-run
                             Exit non-zero unless the latest relevant Router
                             Image dry-run workflow completed successfully,
                             uploaded the preview artifact with normalized
                             metadata tags, skipped GHCR login, has no
                             warning/failure check annotations, and still
                             covers the checked-out router image inputs.
  --show-wamp-profile-benchmarks
                             Print the latest dedicated WAMP Profile Benchmarks
                             workflow evidence.
  --require-clean-wamp-profile-benchmarks
                             Exit non-zero unless the latest relevant WAMP
                             Profile Benchmarks workflow completed successfully,
                             uploaded the benchmark artifacts, and still covers
                             the checked-out WAMP profile benchmark inputs.
  --require-router-package   Exit non-zero unless the GHCR router package is
                             visible through the public registry API or
                             GitHub Packages metadata fallback.
  --require-workflows-visible
                             Exit non-zero unless every checked-in workflow is
                             discoverable through the GitHub Actions API.
  --show-required-checks-plan
                             Print the non-mutating operator plan for adding
                             the baseline required status checks to the audited
                             protected branch.
  --show-rc-readiness        Print a non-mutating release-candidate readiness
                             summary for the current checked-out head aligned
                             with the audited default branch, including stale
                             local/GitHub RC tag evidence.
  --require-rc-ready         Exit non-zero unless the current checked-out head
                             matches the audited default branch and has
                             release-candidate evidence: clean hosted CI and
                             logs, hosted Dart package publish dry-run evidence,
                             hosted native release dry-run or prerelease
                             publish evidence, hosted router image dry-run
                             evidence, hosted WAMP profile benchmark evidence,
                             baseline default-branch protection, visible
                             workflows, visible router package, an RC GitHub
                             prerelease, and either strict Dart package dry-run
                             readiness or the
                             documented first-RC pub.dev deferral where
                             connectanum_client is blocked only by private
                             connectanum_core.
  --strict                  Exit non-zero when the branch lacks the baseline
                             required checks expected for protected releases.
  -h, --help                Show this help text.
USAGE
}

repository="${GITHUB_REPOSITORY:-konsultaner/connectanum-dart}"
branch=""
dart_package_publish_dry_run_bin="${DART_PACKAGE_PUBLISH_DRY_RUN_BIN:-bin/dart-package-publish-dry-run}"
run_limit=6
strict=0
check_clean_latest_ci=0
require_clean_latest_ci=0
check_latest_ci_logs=0
scan_latest_ci_logs=0
require_clean_latest_ci_logs=0
check_dart_package_publish_dry_run=0
require_clean_dart_package_publish_dry_run=0
check_native_release_dry_run=0
require_clean_native_release_dry_run=0
accept_native_prerelease_evidence=0
check_router_image_dry_run=0
require_clean_router_image_dry_run=0
check_wamp_profile_benchmarks=0
require_clean_wamp_profile_benchmarks=0
require_router_package=0
require_workflows_visible=0
show_required_checks_plan=0
show_rc_readiness=0
require_rc_ready=0
expected_ci_jobs=('Fast Checks' 'Full Verify')
dart_package_publish_workflow='Dart Package Publish Dry Run'
expected_dart_package_publish_jobs=('Publish Dry Run')
native_release_workflow='Native Artifacts'
expected_native_release_jobs=(
  'ct_ffi (Linux x64)'
  'ct_ffi (Linux arm64)'
  'ct_ffi (macOS Apple Silicon)'
  'ct_ffi (macOS Intel)'
  'ct_ffi (Windows x64)'
  'Publish GitHub Release'
)
expected_native_release_asset_count=30
router_image_workflow='Router Image'
expected_router_image_jobs=('Publish Router Image')
wamp_profile_benchmarks_workflow='WAMP Profile Benchmarks'
expected_wamp_profile_benchmarks_jobs=('Linux WAMP profile gates')
ci_log_issue_pattern='warning:|::warning|DeprecationWarning|Connection reset by peer|connection ConnectionId|skipped'

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repository)
      [[ $# -ge 2 ]] || {
        printf 'Expected a value after --repository.\n' >&2
        exit 64
      }
      repository="$2"
      shift 2
      ;;
    --repository=*)
      repository="${1#--repository=}"
      shift
      ;;
    --branch)
      [[ $# -ge 2 ]] || {
        printf 'Expected a value after --branch.\n' >&2
        exit 64
      }
      branch="$2"
      shift 2
      ;;
    --branch=*)
      branch="${1#--branch=}"
      shift
      ;;
    --run-limit)
      [[ $# -ge 2 ]] || {
        printf 'Expected a value after --run-limit.\n' >&2
        exit 64
      }
      run_limit="$2"
      shift 2
      ;;
    --run-limit=*)
      run_limit="${1#--run-limit=}"
      shift
      ;;
    --require-clean-latest-ci)
      check_clean_latest_ci=1
      require_clean_latest_ci=1
      shift
      ;;
    --scan-latest-ci-logs)
      check_latest_ci_logs=1
      scan_latest_ci_logs=1
      shift
      ;;
    --require-clean-latest-ci-logs)
      check_latest_ci_logs=1
      scan_latest_ci_logs=1
      require_clean_latest_ci_logs=1
      shift
      ;;
    --show-dart-package-publish-dry-run)
      check_dart_package_publish_dry_run=1
      shift
      ;;
    --require-clean-dart-package-publish-dry-run)
      check_dart_package_publish_dry_run=1
      require_clean_dart_package_publish_dry_run=1
      shift
      ;;
    --show-native-release-dry-run)
      check_native_release_dry_run=1
      shift
      ;;
    --require-clean-native-release-dry-run)
      check_native_release_dry_run=1
      require_clean_native_release_dry_run=1
      shift
      ;;
    --show-router-image-dry-run)
      check_router_image_dry_run=1
      shift
      ;;
    --require-clean-router-image-dry-run)
      check_router_image_dry_run=1
      require_clean_router_image_dry_run=1
      shift
      ;;
    --show-wamp-profile-benchmarks)
      check_wamp_profile_benchmarks=1
      shift
      ;;
    --require-clean-wamp-profile-benchmarks)
      check_wamp_profile_benchmarks=1
      require_clean_wamp_profile_benchmarks=1
      shift
      ;;
    --require-router-package)
      require_router_package=1
      shift
      ;;
    --require-workflows-visible)
      require_workflows_visible=1
      shift
      ;;
    --show-required-checks-plan)
      show_required_checks_plan=1
      shift
      ;;
    --show-rc-readiness)
      show_rc_readiness=1
      check_clean_latest_ci=1
      check_latest_ci_logs=1
      scan_latest_ci_logs=1
      check_dart_package_publish_dry_run=1
      check_native_release_dry_run=1
      accept_native_prerelease_evidence=1
      check_router_image_dry_run=1
      check_wamp_profile_benchmarks=1
      shift
      ;;
    --require-rc-ready)
      show_rc_readiness=1
      require_rc_ready=1
      check_clean_latest_ci=1
      check_latest_ci_logs=1
      scan_latest_ci_logs=1
      check_dart_package_publish_dry_run=1
      check_native_release_dry_run=1
      accept_native_prerelease_evidence=1
      check_router_image_dry_run=1
      check_wamp_profile_benchmarks=1
      shift
      ;;
    --strict)
      strict=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'Unrecognized argument: %s\n' "$1" >&2
      usage >&2
      exit 64
      ;;
  esac
done

if ! [[ "$run_limit" =~ ^[0-9]+$ ]] || [[ "$run_limit" -eq 0 ]]; then
  printf 'Expected --run-limit to be a positive integer, got %s.\n' "$run_limit" >&2
  exit 64
fi

cd_repo_root

gh_bin="${GH_BIN:-}"
if [[ -z "$gh_bin" ]]; then
  if command -v gh >/dev/null 2>&1; then
    gh_bin="$(command -v gh)"
  elif [[ -x "$HOME/bin/gh" ]]; then
    gh_bin="$HOME/bin/gh"
  else
    printf 'Missing required command: gh. Set GH_BIN to the GitHub CLI path if it is not on PATH.\n' >&2
    exit 1
  fi
fi

api_jq() {
  local path="$1"
  local filter="$2"
  local api_path="repos/${repository}"

  if [[ -n "$path" ]]; then
    api_path="${api_path}/${path}"
  fi

  "$gh_bin" api "$api_path" --jq "$filter"
}

api_jq_optional() {
  local path="$1"
  local filter="$2"
  local api_path="repos/${repository}"

  if [[ -n "$path" ]]; then
    api_path="${api_path}/${path}"
  fi

  "$gh_bin" api "$api_path" --jq "$filter" 2>/dev/null || true
}

lowercase() {
  printf '%s\n' "$1" | tr '[:upper:]' '[:lower:]'
}

ghcr_registry_pull_token() {
  local image_owner="$1"
  local token

  command -v curl >/dev/null 2>&1 || return 2
  command -v python3 >/dev/null 2>&1 || return 2

  token="$(
    curl -fsSLG \
      --data-urlencode "scope=repository:${image_owner}/connectanum-router:pull" \
      'https://ghcr.io/token' \
      | python3 -c 'import json, sys; print(json.load(sys.stdin).get("token", ""))'
  )" || return 1

  [[ -n "$token" ]] || return 1
  printf '%s\n' "$token"
}

ghcr_registry_manifest_digest_with_token() {
  local image_owner="$1"
  local token="$2"
  local manifest_tag="$3"
  local manifest_headers
  local manifest_digest

  [[ -n "$manifest_tag" ]] || return 1
  command -v curl >/dev/null 2>&1 || return 2

  manifest_headers="$(
    curl -fsSIL \
      -H "Authorization: Bearer ${token}" \
      -H 'Accept: application/vnd.oci.image.index.v1+json, application/vnd.docker.distribution.manifest.list.v2+json, application/vnd.oci.image.manifest.v1+json, application/vnd.docker.distribution.manifest.v2+json' \
      "https://ghcr.io/v2/${image_owner}/connectanum-router/manifests/${manifest_tag}"
  )" || return 1

  manifest_digest="$(
    printf '%s\n' "$manifest_headers" \
      | awk 'tolower($1) == "docker-content-digest:" { print $2 }' \
      | tr -d '\r' \
      | tail -n 1
  )"

  [[ -n "$manifest_digest" ]] || return 1
  printf '%s\n' "$manifest_digest"
}

ghcr_registry_manifest_digest() {
  local owner="$1"
  local manifest_tag="$2"
  local image_owner
  local token

  image_owner="$(lowercase "$owner")"
  token="$(ghcr_registry_pull_token "$image_owner")" || return 1
  ghcr_registry_manifest_digest_with_token "$image_owner" "$token" "$manifest_tag"
}

router_image_tag_for_rc_tag() {
  local rc_tag="$1"

  if [[ "$rc_tag" == v* ]]; then
    printf '%s\n' "${rc_tag#v}"
  else
    printf '%s\n' "$rc_tag"
  fi
}

ghcr_registry_package_summary() {
  local owner="$1"
  local image_owner
  local token
  local tags_json
  local tags_summary
  local manifest_tag
  local manifest_digest

  image_owner="$(lowercase "$owner")"

  command -v python3 >/dev/null 2>&1 || return 2

  token="$(ghcr_registry_pull_token "$image_owner")" || return 1

  tags_json="$(
    curl -fsSL \
      -H "Authorization: Bearer ${token}" \
      -H 'Accept: application/json' \
      "https://ghcr.io/v2/${image_owner}/connectanum-router/tags/list"
  )" || return 1

  tags_summary="$(printf '%s\n' "$tags_json" | python3 -c '
import json
import sys

data = json.load(sys.stdin)
name = data.get("name") or ""
tags = data.get("tags") or []
if not name or not isinstance(tags, list) or not tags:
    sys.exit(1)

print(name)
print(len(tags))
print(tags[0])
for tag in tags[:10]:
    print(tag)
')" || return 1

  manifest_tag="$(printf '%s\n' "$tags_summary" | sed -n '3p')"
  [[ -n "$manifest_tag" ]] || return 1

  manifest_digest="$(ghcr_registry_manifest_digest_with_token "$image_owner" "$token" "$manifest_tag")" || return 1

  printf '%s\n' "$tags_summary" | sed -n '1,3p'
  printf '%s\n' "$manifest_digest"
  printf '%s\n' "$tags_summary" | sed -n '4,13p'
}

is_expected_ci_job() {
  local candidate="$1"
  local expected_job

  for expected_job in "${expected_ci_jobs[@]}"; do
    if [[ "$candidate" == "$expected_job" ]]; then
      return 0
    fi
  done

  return 1
}

is_expected_dart_package_publish_job() {
  local candidate="$1"
  local expected_job

  for expected_job in "${expected_dart_package_publish_jobs[@]}"; do
    if [[ "$candidate" == "$expected_job" ]]; then
      return 0
    fi
  done

  return 1
}

is_expected_native_release_job() {
  local candidate="$1"
  local expected_job

  for expected_job in "${expected_native_release_jobs[@]}"; do
    if [[ "$candidate" == "$expected_job" ]]; then
      return 0
    fi
  done

  return 1
}

