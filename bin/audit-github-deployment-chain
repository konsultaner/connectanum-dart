  local candidate="$1"
  local expected_job

  for expected_job in "${expected_router_image_jobs[@]}"; do
    if [[ "$candidate" == "$expected_job" ]]; then
      return 0
    fi
  done

  return 1
}

is_expected_wamp_profile_benchmark_job() {
  local candidate="$1"
  local expected_job

  for expected_job in "${expected_wamp_profile_benchmark_jobs[@]}"; do
    if [[ "$candidate" == "$expected_job" ]]; then
      return 0
    fi
  done

  return 1
}

is_release_candidate_tag() {
  local tag="$1"

  [[ "$tag" =~ (^|[-_.])rc([0-9]+|[-_.][0-9]+)?($|[-_.]) ]]
}

rc_tags_pointing_at_head() {
  local tag

  while IFS= read -r tag; do
    [[ -n "$tag" ]] || continue
    if is_release_candidate_tag "$tag"; then
      printf '%s\n' "$tag"
    fi
  done < <(git tag --points-at HEAD | sort)
}

rc_tags_merged_into_head() {
  local tag

  while IFS= read -r tag; do
    [[ -n "$tag" ]] || continue
    if is_release_candidate_tag "$tag"; then
      printf '%s\n' "$tag"
    fi
  done < <(
    git for-each-ref \
      --merged HEAD \
      --sort=-creatordate \
      --format='%(refname:short)' \
      refs/tags
  )
}

rc_candidate_tags_for_head() {
  local head_tags

  if [[ -n "$requested_rc_tag" ]]; then
    printf '%s\n' "$requested_rc_tag"
    return
  fi

  head_tags="$(rc_tags_pointing_at_head)"
  if [[ -n "$head_tags" ]]; then
    printf '%s\n' "$head_tags"
    return
  fi

  rc_tags_merged_into_head
}

rc_readiness_sensitive_changes_since() {
  local base="$1"
  local path

  git diff --name-only "${base}..HEAD" | while IFS= read -r path; do
    case "$path" in
      bin/audit-github-deployment-chain|\
      docs/project_state.md|\
      docs/exec-plans/*)
        ;;
      *)
        printf '%s\n' "$path"
        ;;
    esac
  done
}

ghcr_registry_manifest_exists() {
  local image="$1"
  local reference
  local repository_path
  local tag
  local token

  [[ "$image" == ghcr.io/*:* ]] || return 1
  command -v curl >/dev/null 2>&1 || return 127
  command -v python3 >/dev/null 2>&1 || return 127

  reference="${image#ghcr.io/}"
  repository_path="${reference%:*}"
  tag="${reference##*:}"

  [[ -n "$repository_path" && "$repository_path" != "$reference" ]] || return 1
  [[ -n "$tag" ]] || return 1

  token="$(
    curl -fsSLG \
      --connect-timeout 10 \
      --max-time 30 \
      --data-urlencode 'service=ghcr.io' \
      --data-urlencode "scope=repository:${repository_path}:pull" \
      'https://ghcr.io/token' \
      2>/dev/null \
      | python3 -c 'import json, sys; print(json.load(sys.stdin).get("token", ""))' \
        2>/dev/null
  )" || return 1

  [[ -n "$token" ]] || return 1

  curl -fsSI \
    --connect-timeout 10 \
    --max-time 30 \
    -H "Authorization: Bearer ${token}" \
    -H 'Accept: application/vnd.oci.image.index.v1+json, application/vnd.docker.distribution.manifest.list.v2+json, application/vnd.oci.image.manifest.v1+json, application/vnd.docker.distribution.manifest.v2+json' \
    "https://ghcr.io/v2/${repository_path}/manifests/${tag}" \
    >/dev/null 2>&1
}

inspect_router_image_manifest() {
  local image="$1"

  if ghcr_registry_manifest_exists "$image"; then
    return 0
  fi

  if command -v docker >/dev/null 2>&1 && docker buildx version >/dev/null 2>&1; then
    docker buildx imagetools inspect "$image" >/dev/null 2>&1
    return $?
  fi

  return 1
}

router_image_dry_run_tags_include_rc_tag() {
  local rc_tag="$1"
  local preview_ref
  local preview_tag
  local unprefixed_rc_tag="${rc_tag#v}"

  while IFS= read -r preview_ref; do
    [[ -n "$preview_ref" ]] || continue
    preview_tag="${preview_ref##*:}"
    if [[ "$preview_tag" == "$rc_tag" || "$preview_tag" == "$unprefixed_rc_tag" ]]; then
      return 0
    fi
  done <<<"$latest_router_image_dry_run_tags"

  return 1
}

strict_dart_output_is_deferred_pub_dev_only() {
  local output_file="$1"
  local blocker_lines
  local unexpected_blockers

  grep -Fq 'All Dart package publish dry-runs reported zero warnings.' "$output_file" || return 1
  grep -Fq 'Dart package release-readiness blockers:' "$output_file" || return 1
  grep -Fq 'Private workspace packages blocking publishable targets:' "$output_file" || return 1
  grep -Eq '^- connectanum_core [^ ]+ \(packages/connectanum_core\)$' "$output_file" || return 1

  blocker_lines="$(
    grep -E '^- .+ depends on private workspace package .+' "$output_file" || true
  )"

  [[ -n "$blocker_lines" ]] || return 1

  unexpected_blockers="$(
    printf '%s\n' "$blocker_lines" \
      | grep -Ev '^- connectanum_client depends on private workspace package connectanum_core \(packages/connectanum_core\); publish connectanum_core first or remove the hosted dependency before publishing connectanum_client\.$' \
      || true
  )"

  [[ -z "$unexpected_blockers" ]]
}

latest_workflow_run_id() {
  local workflow="$1"
  local run_id

  run_id="$(
    "$gh_bin" run list \
      --repo "$repository" \
      --branch "$branch" \
      --workflow "$workflow" \
      --limit 1 \
      --json databaseId \
      --jq '.[0].databaseId // empty'
  )"

  if [[ -n "$run_id" ]]; then
    printf '%s\n' "$run_id"
    return 0
  fi

  # GitHub can briefly index a completed run in the branch list before the
  # workflow-filtered list sees it. Fall back to the same branch run feed so a
  # fresh clean run does not false-fail the deployment-chain audit.
  "$gh_bin" run list \
    --repo "$repository" \
    --branch "$branch" \
    --limit "$run_limit" \
    --json name,databaseId \
    --jq '[.[] | select(.name == "'"$workflow"'")][0].databaseId // empty'
}

latest_ci_run_id() {
  latest_workflow_run_id CI
}

latest_dart_package_publish_dry_run_id() {
  latest_workflow_run_id "$dart_package_publish_workflow"
}

latest_native_release_dry_run_id() {
  latest_workflow_run_id "$native_release_workflow"
}

latest_router_image_dry_run_id() {
  latest_workflow_run_id "$router_image_workflow"
}

latest_wamp_profile_benchmarks_id() {
  latest_workflow_run_id "$wamp_profile_benchmarks_workflow"
}

print_run_log_file_scan() {
  local log_file="$1"
  local label="$2"
  local matches_file

  matches_file="$(mktemp "${TMPDIR:-/tmp}/connectanum-run-log-matches.XXXXXX")"

  if LC_ALL=C grep -Eai "$ci_log_issue_pattern" "$log_file" >"$matches_file"; then
    printf 'Potential hosted %s log issues matching: %s\n' "$label" "$ci_log_issue_pattern"
    awk '
      NR <= 200 { print "- " $0 }
      END {
        if (NR > 200) {
          printf("- ... truncated %d additional matching lines\n", NR - 200)
        }
      }
    ' "$matches_file"
    rm -f "$matches_file"
    return 1
  fi

  printf 'Latest %s log scan is clean: no warning/deprecation/skipped/reset/connection-noise patterns found.\n' "$label"
  rm -f "$matches_file"
  return 0
}

print_run_annotation_scan() {
  local run_id="$1"
  local label="$2"
  local jobs_file
  local annotations_file
  local job_annotations_file
  local job_name
  local job_id
  local failed=0

  jobs_file="$(mktemp "${TMPDIR:-/tmp}/connectanum-run-jobs.XXXXXX")"
  annotations_file="$(mktemp "${TMPDIR:-/tmp}/connectanum-run-annotations.XXXXXX")"
  job_annotations_file="$(mktemp "${TMPDIR:-/tmp}/connectanum-run-job-annotations.XXXXXX")"

  if ! "$gh_bin" api "repos/${repository}/actions/runs/${run_id}/jobs?per_page=100" \
    --jq '.jobs[] | [.name, .id] | @tsv' \
    >"$jobs_file"; then
    printf 'Finding: could not inspect GitHub check-run annotations for %s run #%s.\n' "$label" "$run_id"
    rm -f "$jobs_file" "$annotations_file" "$job_annotations_file"
    return 1
  fi

  if [[ ! -s "$jobs_file" ]]; then
    printf 'Finding: %s run #%s has no inspectable check runs for annotation scanning.\n' "$label" "$run_id"
    rm -f "$jobs_file" "$annotations_file" "$job_annotations_file"
    return 1
  fi

  while IFS=$'\t' read -r job_name job_id; do
    [[ -n "$job_name" && -n "$job_id" ]] || continue
    : >"$job_annotations_file"

    if ! "$gh_bin" api "repos/${repository}/check-runs/${job_id}/annotations?per_page=100" \
      --jq '.[] | select(.annotation_level == "warning" or .annotation_level == "failure") | [.annotation_level, (.path // ""), ((.start_line // "") | tostring), ((.message // "") | gsub("[\r\n\t]+"; " "))] | @tsv' \
      >"$job_annotations_file"; then
      printf 'Finding: could not inspect GitHub check-run annotations for %s job %s.\n' "$label" "$job_name"
      failed=1
      continue
    fi

    if [[ -s "$job_annotations_file" ]]; then
      awk -v job="$job_name" -F '\t' '
        {
          location = ""
          if ($2 != "") {
            location = " (" $2
            if ($3 != "") {
              location = location ":" $3
            }
            location = location ")"
          }
          printf("- %s: %s: %s%s\n", job, $1, $4, location)
        }
      ' "$job_annotations_file" >>"$annotations_file"
    fi
  done <"$jobs_file"

  if [[ -s "$annotations_file" ]]; then
    printf 'Potential hosted %s warning/error annotations:\n' "$label"
    awk '
      NR <= 200 { print }
      END {
        if (NR > 200) {
          printf("- ... truncated %d additional annotations\n", NR - 200)
        }
      }
    ' "$annotations_file"
    failed=1
  elif [[ "$failed" -eq 0 ]]; then
    printf 'Latest %s annotation scan is clean: no warning/error annotations found.\n' "$label"
  fi

  rm -f "$jobs_file" "$annotations_file" "$job_annotations_file"
  return "$failed"
}

dart_package_publish_sensitive_changes_since() {
  local base="$1"
  local path

  git diff --name-only "${base}..HEAD" | while IFS= read -r path; do
    case "$path" in
      .github/workflows/dart-package-publish.yml|\
      bin/dart-package-publish-dry-run|\
      docs/dart_package_publishing.md|\
      packages/*|\
      packages/*/**)
        printf '%s\n' "$path"
        ;;
    esac
  done
}

