  printf '\nNative release dry-run audit failed.\n' >&2
  exit 1
fi

if [[ "$require_clean_router_image_dry_run" -eq 1 && "$router_image_dry_run_failed" -ne 0 ]]; then
  printf '\nRouter image dry-run audit failed.\n' >&2
  exit 1
