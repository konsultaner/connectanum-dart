#!/usr/bin/env bash

set -euo pipefail

source "$(dirname "$0")/common.sh"

cd_repo_root
dart_workspace_bootstrap
cargo_workspace_check

run_client_vm_tests() {
  dart test packages/connectanum_client/test/client_test.dart
  dart test packages/connectanum_client/test/client_on_transport_io_events_test.dart
  dart test packages/connectanum_client/test/transport/local
  dart test packages/connectanum_client/test/transport/native/native_library_loader_test.dart
  dart test packages/connectanum_client/test/transport/socket/socket_transport_test.dart
  dart test packages/connectanum_client/test/transport/websocket/websocket_transport_io_test.dart
  dart test packages/connectanum_client/test/transport/native/message_binding_test.dart
  dart test packages/connectanum_client/test/mcp

  if native_runtime_supported; then
    dart test packages/connectanum_client/test/transport/native/e2ee_provider_test.dart
    dart test packages/connectanum_client/test/transport/native/native_transports_test.dart
  else
    printf 'Native client transports require Linux or macOS; skipping native transport tests on %s.\n' "$(uname -s)"
  fi
}

run_router_vm_tests() {
  printf 'Running router suite from package root so package-local test config applies on %s.\n' "$(uname -s)"
  (
    cd packages/connectanum_router
    dart test test --exclude-tags zero_copy_publish
  )
}

run_router_zero_copy_publish_tests() {
  (
    cd packages/connectanum_router
    CONNECTANUM_FORWARD_NATIVE_PUBLISH=1 \
      dart test \
        test/router_worker_session_test.dart \
        test/router_integration_native_test.dart \
        --tags zero_copy_publish \
        --chain-stack-traces
  )
}

run_bench_vm_tests() {
  printf 'Running bench suite from package root so package-local test config applies on %s.\n' "$(uname -s)"
  (
    cd packages/connectanum_bench
    env -u CONNECTANUM_NATIVE_LIB CONNECTANUM_SKIP_NATIVE_BUILD=1 dart test test
  )
}

run_client_browser_websocket_test() {
  (
    cd packages/connectanum_client
    local attempt_timeout_seconds
    local browser_compiler
    local max_attempts
    local status

    browser_compiler=dart2wasm
    if [[ "${CI:-}" == "true" && "$(uname -s)" == "Linux" ]]; then
      browser_compiler=dart2js
      printf 'Using dart2js for hosted Linux browser smoke; dart2wasm hybrid browser loading is unstable under CI Chrome.\n'
    fi

    max_attempts="${CONNECTANUM_BROWSER_TEST_ATTEMPTS:-2}"
    if ! [[ "$max_attempts" =~ ^[1-9][0-9]*$ ]]; then
      printf 'CONNECTANUM_BROWSER_TEST_ATTEMPTS must be a positive integer, got %s.\n' "$max_attempts" >&2
      return 2
    fi

    attempt_timeout_seconds="${CONNECTANUM_BROWSER_TEST_ATTEMPT_TIMEOUT_SECONDS:-420}"
    if ! [[ "$attempt_timeout_seconds" =~ ^[1-9][0-9]*$ ]]; then
      printf 'CONNECTANUM_BROWSER_TEST_ATTEMPT_TIMEOUT_SECONDS must be a positive integer, got %s.\n' "$attempt_timeout_seconds" >&2
      return 2
    fi

    run_browser_websocket_test_attempt() {
      local timeout_seconds
      timeout_seconds="$1"
      shift

      "$@" &
      local command_pid=$!

      (
        sleep "$timeout_seconds"
        if kill -0 "$command_pid" 2>/dev/null; then
          printf 'Browser WebSocket smoke exceeded %ss; terminating stalled attempt.\n' "$timeout_seconds" >&2
          kill "$command_pid" 2>/dev/null || true
          sleep 2
          kill -9 "$command_pid" 2>/dev/null || true
        fi
      ) &
      local timeout_pid=$!

      local command_status
      if wait "$command_pid"; then
        command_status=0
      else
        command_status=$?
      fi

      kill "$timeout_pid" 2>/dev/null || true
      wait "$timeout_pid" 2>/dev/null || true

      return "$command_status"
    }

    for attempt in $(seq 1 "$max_attempts"); do
      local args=(
        test/transport/websocket/websocket_transport_web_test.dart
        -p chrome
        --compiler="$browser_compiler"
        --timeout=5m
        --concurrency=1
      )

      # Keep retryable package:test browser-manager startup flakes out of
      # GitHub annotations; the final attempt keeps the default reporter.
      if (( attempt < max_attempts )); then
        args+=(--reporter=expanded)
      fi

      if run_browser_websocket_test_attempt "$attempt_timeout_seconds" dart test "${args[@]}"; then
        return 0
      else
        status=$?
      fi

      if (( attempt == max_attempts )); then
        return "$status"
      fi

      printf 'Browser WebSocket smoke failed on attempt %s/%s; retrying.\n' "$attempt" "$max_attempts" >&2
      sleep 2
    done
  )
}

if native_runtime_supported; then
  cargo test --manifest-path native/transport/Cargo.toml -p ct_core
  cargo test --manifest-path native/transport/Cargo.toml -p ct_ffi
  cargo test \
    --manifest-path native/transport/Cargo.toml \
    -p ct_ffi \
    --features ffi-test \
    router_metrics_snapshot_aggregates_reason_totals_and_listener_breakdowns
else
  printf 'Native Rust runtime tests require Linux or macOS; skipping them on %s.\n' "$(uname -s)"
fi

build_native_ffi_test_release

python3 tool/test_package_native_artifact.py
python3 tool/test_verification_scripts.py
python3 tool/check_public_artifact_references.py
python3 tool/test_public_artifact_references.py
python3 tool/test_dart_package_publish_dry_run.py
python3 tool/test_audit_github_deployment_chain.py
dart test packages/connectanum_core/test
dart test packages/connectanum_mcp/test
run_mcp_server_package_smoke
run_mcp_client_package_smoke
run_client_vm_tests
dart test packages/connectanum_auth_server/test
run_bench_vm_tests
run_router_hosted_mcp_example_smoke
run_mcp_consumer_package_smoke
run_router_vm_tests
run_router_zero_copy_publish_tests

if ensure_chrome_env; then
  run_client_browser_websocket_test
else
  printf 'Chrome not found; skipping browser-platform tests.\n'
fi
