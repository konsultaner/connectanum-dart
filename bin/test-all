#!/usr/bin/env bash

set -euo pipefail

source "$(dirname "$0")/common.sh"

cd_repo_root
dart_workspace_bootstrap
cargo_workspace_check

run_client_vm_tests() {
  dart test packages/connectanum_client/test/client_test.dart
  dart test packages/connectanum_client/test/client_on_transport_io_events_test.dart
  dart test packages/connectanum_client/test/transport/local
  dart test packages/connectanum_client/test/transport/socket/socket_transport_test.dart
  dart test packages/connectanum_client/test/transport/websocket/websocket_transport_io_test.dart
  dart test packages/connectanum_client/test/transport/native/message_binding_test.dart

  if native_runtime_supported; then
    dart test packages/connectanum_client/test/transport/native/native_transports_test.dart
  else
    printf 'Native client transports are only supported on Linux; skipping native transport tests on %s.\n' "$(uname -s)"
  fi
}

run_router_vm_tests() {
  if [[ "$(uname -s)" == "Linux" ]]; then
    dart test packages/connectanum_router/test
    return 0
  fi

  if [[ "$(uname -s)" == "Darwin" ]]; then
    printf 'Running the macOS-safe router suite with sequential native integration slices.\n'
  else
    printf 'Native router integration tests are only supported on Linux/macOS; skipping them on %s.\n' "$(uname -s)"
  fi
  dart test packages/connectanum_router/test/authorization_test.dart
  dart test packages/connectanum_router/test/http_auth_provider_test.dart
  dart test packages/connectanum_router/test/http_route_transport_auth_test.dart
  dart test packages/connectanum_router/test/listener_endpoint_resolver_test.dart
  dart test packages/connectanum_router/test/native/ffi_test_mode_test.dart --concurrency=1
  dart test packages/connectanum_router/test/native/message_binding_test.dart
  dart test packages/connectanum_router/test/native/native_library_loader_test.dart
  dart test packages/connectanum_router/test/native/native_runtime_test.dart --concurrency=1
  dart test packages/connectanum_router/test/native_http_request_body_test.dart
  dart test packages/connectanum_router/test/open_metrics_http_server_test.dart
  if [[ "$(uname -s)" == "Darwin" ]]; then
    dart test packages/connectanum_router/test/router_integration_native_test.dart --concurrency=1
    dart test packages/connectanum_router/test/router_integration_websocket_test.dart --concurrency=1
  fi
  dart test packages/connectanum_router/test/remote_wamp_delegate_test.dart
  dart test packages/connectanum_router/test/router_config_loader_test.dart
  dart test packages/connectanum_router/test/router_config_test.dart
  dart test packages/connectanum_router/test/router_integration_cancel_test.dart
  dart test packages/connectanum_router/test/router_json_test.dart
  dart test packages/connectanum_router/test/router_metrics_service_test.dart
  dart test packages/connectanum_router/test/router_metrics_test.dart
  dart test packages/connectanum_router/test/router_runtime_test.dart
  dart test packages/connectanum_router/test/router_worker_auth_test.dart
  dart test packages/connectanum_router/test/router_worker_session_test.dart --chain-stack-traces
  dart test packages/connectanum_router/test/state/pattern_matching_test.dart
}

if native_runtime_supported; then
  cargo test --manifest-path native/transport/Cargo.toml -p ct_core
  cargo test --manifest-path native/transport/Cargo.toml -p ct_ffi
else
  printf 'Native Rust runtime tests are only supported on Linux; skipping them on %s.\n' "$(uname -s)"
fi

build_native_ffi_test_release

dart test packages/connectanum_core/test
run_client_vm_tests
dart test packages/connectanum_auth_server/test
dart test packages/connectanum_bench/test
run_router_vm_tests

if ensure_chrome_env; then
  (
    cd packages/connectanum_client
    dart test \
      test/transport/websocket/websocket_transport_web_test.dart \
      -p chrome \
      --timeout=5m \
      --concurrency=1
  )
else
  printf 'Chrome not found; skipping browser-platform tests.\n'
fi
